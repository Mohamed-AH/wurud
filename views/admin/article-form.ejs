<!DOCTYPE html>
<html lang="<%= adminLocale %>" dir="<%= adminDir %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= isEdit ? t('admin_articles_edit') : t('admin_articles_add') %> - <%= t('admin_title') %></title>
  <link rel="stylesheet" href="/css/admin.css">
  <% if (adminIsRTL) { %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Naskh+Arabic:wght@400;500;600;700&display=swap" rel="stylesheet">
  <% } %>
  <style>
    .form-container {
      max-width: 900px;
      margin: 0 auto;
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
      padding: 24px;
    }
    .form-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 24px;
      padding-bottom: 16px;
      border-bottom: 1px solid #eee;
    }
    .form-header h2 {
      margin: 0;
    }
    .back-link {
      color: #666;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .back-link:hover {
      color: #333;
    }
    .form-group {
      margin-bottom: 20px;
    }
    .form-group label {
      display: block;
      font-weight: 600;
      margin-bottom: 6px;
      color: #333;
    }
    .form-group .hint {
      font-size: 12px;
      color: #888;
      margin-top: 4px;
    }
    .form-group input[type="text"],
    .form-group input[type="url"],
    .form-group input[type="date"],
    .form-group select,
    .form-group textarea {
      width: 100%;
      padding: 10px 12px;
      border: 1px solid #ddd;
      border-radius: 6px;
      font-size: 14px;
      font-family: inherit;
      box-sizing: border-box;
    }
    .form-group textarea {
      min-height: 120px;
      resize: vertical;
    }
    .form-group textarea.content-editor {
      min-height: 300px;
      direction: rtl;
      text-align: right;
      line-height: 1.8;
    }
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: #C49A3C;
      box-shadow: 0 0 0 3px rgba(196, 154, 60, 0.1);
    }
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
    @media (max-width: 600px) {
      .form-row {
        grid-template-columns: 1fr;
      }
    }
    .checkbox-group {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .checkbox-group input[type="checkbox"] {
      width: 18px;
      height: 18px;
    }
    .form-actions {
      display: flex;
      gap: 12px;
      margin-top: 24px;
      padding-top: 20px;
      border-top: 1px solid #eee;
    }
    .btn {
      padding: 10px 20px;
      border-radius: 6px;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      border: 1px solid transparent;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    .btn-primary {
      background: #C49A3C;
      color: #fff;
    }
    .btn-primary:hover {
      background: #a8832f;
    }
    .btn-secondary {
      background: #fff;
      color: #666;
      border-color: #ddd;
    }
    .btn-secondary:hover {
      background: #f5f5f5;
    }
    .btn-danger {
      background: #fff;
      color: #c00;
      border-color: #c00;
    }
    .btn-danger:hover {
      background: #fee;
    }
    .alert {
      padding: 12px 16px;
      border-radius: 6px;
      margin-bottom: 16px;
    }
    .alert-error {
      background: #f8d7da;
      color: #721c24;
      border: 1px solid #f5c6cb;
    }
    .preview-link {
      font-size: 13px;
      color: #666;
    }
    .preview-link a {
      color: #C49A3C;
    }
    .rtl-input {
      direction: rtl;
      text-align: right;
    }
  </style>
</head>
<body>
  <%- include('partials/header') %>

  <main class="admin-container">
    <div class="form-container">
      <div class="form-header">
        <h2><%= isEdit ? t('admin_articles_edit') : t('admin_articles_add') %></h2>
        <a href="/admin/articles" class="back-link">
          &larr; <%= t('admin_btn_back') %>
        </a>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error">
          <%= t('admin_msg_error') %>: <%= error %>
        </div>
      <% } %>

      <form method="POST" action="<%= isEdit ? `/admin/articles/${article._id}/edit` : '/admin/articles/new' %>">
        <div class="form-group">
          <label for="title"><%= t('admin_th_title') %> *</label>
          <input type="text" id="title" name="title" class="rtl-input" required
                 value="<%= isEdit ? article.title : '' %>"
                 placeholder="عنوان المقال...">
        </div>

        <div class="form-group">
          <label for="summary"><%= t('admin_articles_summary') %></label>
          <textarea id="summary" name="summary" class="rtl-input" rows="3"
                    placeholder="ملخص قصير للمقال..."><%= isEdit ? (article.summary || '') : '' %></textarea>
          <div class="hint">Optional. Used for article cards and SEO description.</div>
        </div>

        <div class="form-group">
          <label for="content"><%= t('admin_articles_content') %> *</label>
          <textarea id="content" name="content" class="content-editor" required
                    placeholder="محتوى المقال الكامل..."><%= isEdit ? article.content : '' %></textarea>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="type"><%= t('admin_articles_type') %></label>
            <select id="type" name="type">
              <option value="Asdaa" <%= (isEdit && article.type === 'Asdaa') ? 'selected' : '' %>>
                <%= t('admin_articles_type_asdaa') %>
              </option>
              <option value="TelegramArticle" <%= (isEdit && article.type === 'TelegramArticle') ? 'selected' : '' %>>
                <%= t('admin_articles_type_telegram') %>
              </option>
            </select>
          </div>

          <div class="form-group">
            <label for="publishedAt"><%= t('admin_articles_published_at') %></label>
            <input type="date" id="publishedAt" name="publishedAt"
                   value="<%= isEdit && article.publishedAt ? new Date(article.publishedAt).toISOString().split('T')[0] : new Date().toISOString().split('T')[0] %>">
          </div>
        </div>

        <div class="form-group">
          <label for="sourceUrl"><%= t('admin_articles_source_url') %></label>
          <input type="url" id="sourceUrl" name="sourceUrl"
                 value="<%= isEdit ? (article.sourceUrl || '') : '' %>"
                 placeholder="https://...">
          <div class="hint">Original source URL (e.g., Telegram post link)</div>
        </div>

        <% if (isEdit) { %>
        <div class="form-group">
          <label for="slug">Slug</label>
          <input type="text" id="slug" name="slug"
                 value="<%= article.slug || '' %>"
                 placeholder="auto-generated-slug">
          <div class="hint">
            URL-friendly identifier. Auto-generated if empty.
            <% if (article.slug) { %>
              <span class="preview-link">
                Preview: <a href="/articles/<%= article.slug %>" target="_blank">/articles/<%= article.slug %></a>
              </span>
            <% } %>
          </div>
        </div>
        <% } %>

        <div class="form-group">
          <div class="checkbox-group">
            <input type="checkbox" id="isPublished" name="isPublished"
                   <%= (isEdit && article.isPublished) ? 'checked' : '' %>>
            <label for="isPublished" style="margin-bottom: 0;"><%= t('admin_status_published') %></label>
          </div>
          <div class="hint">Unpublished articles are only visible in admin.</div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">
            <%= isEdit ? t('admin_btn_update') : t('admin_btn_create') %>
          </button>
          <a href="/admin/articles" class="btn btn-secondary">
            <%= t('admin_btn_cancel') %>
          </a>
          <% if (isEdit) { %>
            <button type="button" class="btn btn-danger" onclick="deleteArticle()">
              <%= t('admin_btn_delete') %>
            </button>
          <% } %>
        </div>
      </form>
    </div>
  </main>

  <% if (isEdit) { %>
  <script>
    async function deleteArticle() {
      if (!confirm('<%= t("admin_msg_confirm_delete") %>')) {
        return;
      }

      try {
        const response = await fetch('/admin/articles/<%= article._id %>/delete', {
          method: 'POST',
          headers: { 'Accept': 'application/json' }
        });

        const result = await response.json();
        if (result.success) {
          window.location.href = '/admin/articles?success=article_deleted';
        } else {
          alert(result.message || 'Delete failed');
        }
      } catch (error) {
        console.error('Delete error:', error);
        alert('An error occurred');
      }
    }
  </script>
  <% } %>
</body>
</html>
