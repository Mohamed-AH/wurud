<!DOCTYPE html>
<html lang="<%= adminLocale %>" dir="<%= adminDir %>">
<head>
  <%- include('partials/head') %>
  <title><%= adminLocale === 'ar' ? 'وضع الصيانة' : 'Maintenance Mode' %> - <%= t('admin_title') %></title>
  <style>
    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 24px;
    }

    [dir="rtl"] .page-header {
      flex-direction: row-reverse;
    }

    .page-title {
      font-size: 28px;
      font-weight: 600;
      color: #1A5F5A;
    }

    .back-link {
      color: #1A5F5A;
      text-decoration: none;
      font-size: 14px;
    }

    .back-link:hover {
      text-decoration: underline;
    }

    .config-card {
      background: white;
      border-radius: 12px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      padding: 30px;
      max-width: 800px;
    }

    .config-section {
      margin-bottom: 28px;
    }

    .config-section h3 {
      font-size: 18px;
      font-weight: 600;
      color: #1A5F5A;
      margin-bottom: 16px;
      padding-bottom: 8px;
      border-bottom: 2px solid #f0f0f0;
    }

    .warning-box {
      background: #fff3cd;
      border: 1px solid #ffc107;
      border-radius: 8px;
      padding: 16px;
      margin-bottom: 24px;
      display: flex;
      align-items: flex-start;
      gap: 12px;
    }

    [dir="rtl"] .warning-box {
      flex-direction: row-reverse;
    }

    .warning-box .warning-icon {
      font-size: 24px;
      flex-shrink: 0;
    }

    .warning-box .warning-text {
      color: #856404;
      font-size: 14px;
      line-height: 1.5;
    }

    .toggle-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 0;
      border-bottom: 1px solid #f5f5f5;
    }

    [dir="rtl"] .toggle-row {
      flex-direction: row-reverse;
    }

    .toggle-row:last-child {
      border-bottom: none;
    }

    .toggle-info {
      flex: 1;
    }

    .toggle-info .toggle-title {
      font-weight: 500;
      font-size: 15px;
      color: #333;
      margin-bottom: 2px;
    }

    .toggle-info .toggle-desc {
      font-size: 12px;
      color: #888;
    }

    .toggle-switch {
      position: relative;
      width: 48px;
      height: 26px;
      flex-shrink: 0;
    }

    .toggle-switch input {
      opacity: 0;
      width: 0;
      height: 0;
    }

    .toggle-slider {
      position: absolute;
      cursor: pointer;
      top: 0; left: 0; right: 0; bottom: 0;
      background-color: #ccc;
      border-radius: 26px;
      transition: .3s;
    }

    .toggle-slider::before {
      content: "";
      position: absolute;
      height: 20px;
      width: 20px;
      left: 3px;
      bottom: 3px;
      background-color: white;
      border-radius: 50%;
      transition: .3s;
    }

    .toggle-switch input:checked + .toggle-slider {
      background-color: #dc3545;
    }

    .toggle-switch input:checked + .toggle-slider::before {
      transform: translateX(22px);
    }

    .form-group {
      margin-bottom: 20px;
    }

    .form-group label {
      display: block;
      font-weight: 500;
      margin-bottom: 8px;
      color: #333;
    }

    .form-group input[type="text"],
    .form-group input[type="url"],
    .form-group textarea {
      width: 100%;
      padding: 10px 14px;
      border: 1px solid #ddd;
      border-radius: 6px;
      font-size: 14px;
      transition: border-color 0.2s;
    }

    .form-group input[type="text"]:focus,
    .form-group input[type="url"]:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: #1A5F5A;
    }

    .form-group textarea {
      min-height: 80px;
      resize: vertical;
    }

    .form-group .hint {
      font-size: 12px;
      color: #888;
      margin-top: 4px;
    }

    .language-section {
      background: #f8f9fa;
      border-radius: 8px;
      padding: 20px;
      margin-bottom: 20px;
    }

    .language-section h4 {
      font-size: 16px;
      font-weight: 600;
      color: #1A5F5A;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    [dir="rtl"] .language-section h4 {
      flex-direction: row-reverse;
    }

    .language-flag {
      font-size: 20px;
    }

    .btn-save {
      background: #1A5F5A;
      color: white;
      padding: 12px 30px;
      border: none;
      border-radius: 8px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      margin-top: 16px;
    }

    .btn-save:hover {
      background: #155450;
    }

    .alert {
      padding: 12px 16px;
      border-radius: 6px;
      margin-bottom: 16px;
    }

    .alert-success {
      background: #d4edda;
      color: #155724;
      border: 1px solid #c3e6cb;
    }

    .alert-danger {
      background: #f8d7da;
      color: #721c24;
      border: 1px solid #f5c6cb;
    }

    .preview-section {
      background: #1a1a2e;
      border: 1px solid #16213e;
      border-radius: 8px;
      padding: 24px;
      margin-bottom: 24px;
    }

    .preview-section h4 {
      font-size: 14px;
      font-weight: 600;
      color: #aaa;
      margin-bottom: 16px;
    }

    .maintenance-preview {
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
      border-radius: 12px;
      padding: 40px 24px;
      text-align: center;
      color: white;
    }

    .maintenance-preview.disabled {
      opacity: 0.4;
    }

    .maintenance-preview .preview-icon {
      font-size: 48px;
      margin-bottom: 16px;
    }

    .maintenance-preview .preview-title {
      font-size: 24px;
      font-weight: 700;
      margin-bottom: 12px;
      color: #f0c14b;
    }

    .maintenance-preview .preview-message {
      font-size: 16px;
      color: #ccc;
      margin-bottom: 20px;
      line-height: 1.6;
    }

    .maintenance-preview .preview-telegram {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #0088cc;
      color: white;
      padding: 12px 24px;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 600;
    }

    [dir="rtl"] .maintenance-preview .preview-telegram {
      flex-direction: row-reverse;
    }

    .status-badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
      margin-left: 8px;
    }

    [dir="rtl"] .status-badge {
      margin-left: 0;
      margin-right: 8px;
    }

    .status-badge.active {
      background: #f8d7da;
      color: #721c24;
    }

    .status-badge.inactive {
      background: #d4edda;
      color: #155724;
    }
  </style>
</head>
<body>
  <%- include('partials/header', { activePage: 'sections' }) %>

  <main class="admin-container">
    <div class="page-header">
      <h2 class="page-title">
        <%= adminLocale === 'ar' ? 'وضع الصيانة' : 'Maintenance Mode' %>
        <span class="status-badge <%= settings.enabled ? 'active' : 'inactive' %>" id="statusBadge">
          <%= settings.enabled ? (adminLocale === 'ar' ? 'مفعّل' : 'ACTIVE') : (adminLocale === 'ar' ? 'معطّل' : 'OFF') %>
        </span>
      </h2>
      <a href="/admin/dashboard" class="back-link"><%= adminLocale === 'ar' ? '← العودة للوحة التحكم' : '← Back to Dashboard' %></a>
    </div>

    <% if (settings.enabled) { %>
    <div class="warning-box">
      <span class="warning-icon">⚠️</span>
      <div class="warning-text">
        <%= adminLocale === 'ar'
          ? 'وضع الصيانة مفعّل حالياً. سيرى جميع الزوار شاشة الصيانة بدلاً من محتوى الموقع. صفحات الإدارة لا تتأثر.'
          : 'Maintenance mode is currently ACTIVE. All visitors will see the maintenance screen instead of site content. Admin pages are not affected.' %>
      </div>
    </div>
    <% } %>

    <% if (success) { %>
      <div class="alert alert-success">
        <%= t('admin_msg_saved') %>
      </div>
    <% } %>

    <% if (error) { %>
      <div class="alert alert-danger">
        <%= t('admin_msg_error') %>
      </div>
    <% } %>

    <div class="preview-section">
      <h4><%= adminLocale === 'ar' ? 'معاينة شاشة الصيانة' : 'Maintenance Screen Preview' %></h4>
      <div class="maintenance-preview <%= settings.enabled ? '' : 'disabled' %>" id="maintenancePreview" dir="<%= adminLocale === 'ar' ? 'rtl' : 'ltr' %>">
        <div class="preview-icon">🔧</div>
        <div class="preview-title" id="previewTitle"><%= adminLocale === 'ar' ? (settings.titleAr || 'الموقع تحت الصيانة') : (settings.titleEn || 'Site Under Maintenance') %></div>
        <div class="preview-message" id="previewMessage"><%= adminLocale === 'ar' ? (settings.messageAr || 'نعمل حالياً على تحسين الموقع.') : (settings.messageEn || 'We are currently improving the site.') %></div>
        <a href="<%= settings.telegramUrl || 'https://t.me/daririhasan' %>" target="_blank" class="preview-telegram" id="previewTelegram">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69a.2.2 0 00-.05-.18c-.06-.05-.14-.03-.21-.02-.09.02-1.49.95-4.22 2.79-.4.27-.76.41-1.08.4-.36-.01-1.04-.2-1.55-.37-.63-.2-1.12-.31-1.08-.66.02-.18.27-.36.74-.55 2.92-1.27 4.86-2.11 5.83-2.51 2.78-1.16 3.35-1.36 3.73-1.36.08 0 .27.02.39.12.1.08.13.19.14.27-.01.06.01.24 0 .38z"/></svg>
          <span id="previewTelegramText"><%= adminLocale === 'ar' ? (settings.telegramTextAr || 'تابعنا على تيليجرام') : (settings.telegramTextEn || 'Follow us on Telegram') %></span>
        </a>
      </div>
    </div>

    <div class="config-card">
      <form method="POST" action="/admin/maintenance-mode">

        <div class="config-section">
          <h3><%= adminLocale === 'ar' ? 'حالة وضع الصيانة' : 'Maintenance Mode Status' %></h3>

          <div class="toggle-row">
            <div class="toggle-info">
              <div class="toggle-title"><%= adminLocale === 'ar' ? 'تفعيل وضع الصيانة' : 'Enable Maintenance Mode' %></div>
              <div class="toggle-desc"><%= adminLocale === 'ar' ? 'عند التفعيل، سيتم عرض شاشة الصيانة لجميع الزوار (ما عدا صفحات الإدارة)' : 'When enabled, all visitors will see the maintenance screen (except admin pages)' %></div>
            </div>
            <label class="toggle-switch">
              <input type="checkbox" name="enabled" <%= settings.enabled ? 'checked' : '' %> onchange="updateMaintenanceStatus(this.checked)">
              <span class="toggle-slider"></span>
            </label>
          </div>
        </div>

        <div class="config-section">
          <h3><%= adminLocale === 'ar' ? 'العنوان والرسالة' : 'Title & Message' %></h3>

          <div class="language-section">
            <h4><span class="language-flag">🇸🇦</span> <%= adminLocale === 'ar' ? 'المحتوى بالعربية' : 'Arabic Content' %></h4>
            <div class="form-group">
              <label for="titleAr"><%= adminLocale === 'ar' ? 'العنوان' : 'Title' %></label>
              <input type="text" id="titleAr" name="titleAr" dir="rtl" value="<%= settings.titleAr || '' %>" placeholder="الموقع تحت الصيانة">
            </div>
            <div class="form-group">
              <label for="messageAr"><%= adminLocale === 'ar' ? 'الرسالة' : 'Message' %></label>
              <textarea id="messageAr" name="messageAr" dir="rtl" placeholder="نعمل حالياً على تحسين الموقع. يرجى العودة قريباً."><%= settings.messageAr || '' %></textarea>
            </div>
            <div class="form-group">
              <label for="telegramTextAr"><%= adminLocale === 'ar' ? 'نص زر تيليجرام' : 'Telegram Button Text' %></label>
              <input type="text" id="telegramTextAr" name="telegramTextAr" dir="rtl" value="<%= settings.telegramTextAr || '' %>" placeholder="تابعنا على تيليجرام للتحديثات">
            </div>
          </div>

          <div class="language-section">
            <h4><span class="language-flag">🇺🇸</span> <%= adminLocale === 'ar' ? 'المحتوى بالإنجليزية' : 'English Content' %></h4>
            <div class="form-group">
              <label for="titleEn"><%= adminLocale === 'ar' ? 'العنوان' : 'Title' %></label>
              <input type="text" id="titleEn" name="titleEn" dir="ltr" value="<%= settings.titleEn || '' %>" placeholder="Site Under Maintenance">
            </div>
            <div class="form-group">
              <label for="messageEn"><%= adminLocale === 'ar' ? 'الرسالة' : 'Message' %></label>
              <textarea id="messageEn" name="messageEn" dir="ltr" placeholder="We are currently improving the site. Please check back soon."><%= settings.messageEn || '' %></textarea>
            </div>
            <div class="form-group">
              <label for="telegramTextEn"><%= adminLocale === 'ar' ? 'نص زر تيليجرام' : 'Telegram Button Text' %></label>
              <input type="text" id="telegramTextEn" name="telegramTextEn" dir="ltr" value="<%= settings.telegramTextEn || '' %>" placeholder="Follow us on Telegram for updates">
            </div>
          </div>
        </div>

        <div class="config-section">
          <h3><%= adminLocale === 'ar' ? 'رابط تيليجرام' : 'Telegram Link' %></h3>

          <div class="form-group">
            <label for="telegramUrl"><%= adminLocale === 'ar' ? 'رابط قناة تيليجرام' : 'Telegram Channel URL' %></label>
            <input type="url" id="telegramUrl" name="telegramUrl" dir="ltr" value="<%= settings.telegramUrl || '' %>" placeholder="https://t.me/daririhasan">
            <div class="hint"><%= adminLocale === 'ar' ? 'رابط قناة تيليجرام للتواصل مع الزوار أثناء فترة الصيانة' : 'Telegram channel link for visitors to stay updated during maintenance' %></div>
          </div>
        </div>

        <button type="submit" class="btn-save"><%= t('admin_btn_save') %></button>
      </form>
    </div>
  </main>

  <script>
    function updateMaintenanceStatus(isEnabled) {
      const preview = document.getElementById('maintenancePreview');
      const badge = document.getElementById('statusBadge');

      if (isEnabled) {
        preview.classList.remove('disabled');
        badge.className = 'status-badge active';
        badge.textContent = '<%= adminLocale === "ar" ? "مفعّل" : "ACTIVE" %>';
      } else {
        preview.classList.add('disabled');
        badge.className = 'status-badge inactive';
        badge.textContent = '<%= adminLocale === "ar" ? "معطّل" : "OFF" %>';
      }
    }

    // Live preview updates
    const locale = '<%= adminLocale %>';

    document.getElementById('titleAr')?.addEventListener('input', function() {
      if (locale === 'ar') document.getElementById('previewTitle').textContent = this.value || 'الموقع تحت الصيانة';
    });

    document.getElementById('titleEn')?.addEventListener('input', function() {
      if (locale === 'en') document.getElementById('previewTitle').textContent = this.value || 'Site Under Maintenance';
    });

    document.getElementById('messageAr')?.addEventListener('input', function() {
      if (locale === 'ar') document.getElementById('previewMessage').textContent = this.value || 'نعمل حالياً على تحسين الموقع.';
    });

    document.getElementById('messageEn')?.addEventListener('input', function() {
      if (locale === 'en') document.getElementById('previewMessage').textContent = this.value || 'We are currently improving the site.';
    });

    document.getElementById('telegramTextAr')?.addEventListener('input', function() {
      if (locale === 'ar') document.getElementById('previewTelegramText').textContent = this.value || 'تابعنا على تيليجرام';
    });

    document.getElementById('telegramTextEn')?.addEventListener('input', function() {
      if (locale === 'en') document.getElementById('previewTelegramText').textContent = this.value || 'Follow us on Telegram';
    });
  </script>
</body>
</html>
