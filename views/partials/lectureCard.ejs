<div class="lecture-card" data-lecture-number="<%= lecture.lectureNumber || '' %>">
  <!-- Number badge inside card (visible on mobile) -->
  <div class="lecture-number-inside"><%= lecture.lectureNumber || '' %></div>

  <div class="lecture-icon">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path>
      <path d="M19 10v2a7 7 0 0 1-14 0v-2"></path>
      <line x1="12" y1="19" x2="12" y2="23"></line>
      <line x1="8" y1="23" x2="16" y2="23"></line>
    </svg>
  </div>

  <div class="lecture-content">
    <h3 class="lecture-title">
      <a href="/lectures/<%= lecture.shortId ? lecture.shortId + '/' + (lecture.slug_en || '') + '/' + encodeURIComponent(lecture.slug_ar || '') : (lecture.slug ? encodeURIComponent(lecture.slug) : lecture._id) %>"><%= locale === 'ar' ? lecture.titleArabic : (lecture.titleEnglish || lecture.titleArabic) %></a>
    </h3>

    <div class="lecture-meta">
      <span class="lecture-sheikh">
        <% if (lecture.sheikhId) { %>
          <%= locale === 'ar' ? lecture.sheikhId.nameArabic : (lecture.sheikhId.nameEnglish || lecture.sheikhId.nameArabic) %>
          <% if (lecture.sheikhId.honorific && locale === 'ar') { %>
            <%= lecture.sheikhId.honorific %>
          <% } %>
        <% } %>
      </span>

      <% if (lecture.seriesId) { %>
        <span class="lecture-divider">•</span>
        <span class="lecture-series"><%= locale === 'ar' ? lecture.seriesId.titleArabic : (lecture.seriesId.titleEnglish || lecture.seriesId.titleArabic) %></span>
      <% } %>
    </div>

    <div class="lecture-info">
      <% if (lecture.duration && lecture.duration > 0) { %>
        <span class="lecture-duration">⏱️ <%= lecture.durationFormatted %></span>
        <span class="lecture-divider">•</span>
      <% } %>
      <span class="lecture-plays"><i data-lucide="play"></i> <%= lecture.playCount %> <%= locale === 'ar' ? 'مرة' : 'plays' %></span>
      <% if (lecture.dateRecordedHijri) { %>
        <span class="lecture-divider">•</span>
        <span class="lecture-date" title="<%= locale === 'ar' ? 'تاريخ التسجيل (هجري)' : 'Recording Date (Hijri)' %>">
          <i data-lucide="calendar"></i> <%= formatHijriDate(lecture.dateRecordedHijri) %>
        </span>
      <% } %>
      <% if (lecture.category && lecture.category !== 'Other') { %>
        <span class="lecture-divider">•</span>
        <span class="lecture-category"><%= translateCategory(lecture.category) %></span>
      <% } %>
    </div>
  </div>

  <div class="lecture-actions">
    <% if (lecture.audioFileName) { %>
      <% const displayTitle = locale === 'ar' ? (lecture.titleArabic || '') : (lecture.titleEnglish || lecture.titleArabic || ''); %>
      <% const displaySheikh = lecture.sheikhId ? (locale === 'ar' ? lecture.sheikhId.nameArabic : (lecture.sheikhId.nameEnglish || lecture.sheikhId.nameArabic)) : ''; %>
      <button class="btn-play" onclick="playAudio('<%= lecture._id %>', '<%= displayTitle.replace(/'/g, "\\'") %>', '<%= displaySheikh.replace(/'/g, "\\'") %>')" title="<%= typeof t === 'function' ? t('lecture_play') : (locale === 'ar' ? 'استماع' : 'Play') %>">
        <svg class="play-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
      </button>
    <% } else { %>
      <button class="btn-play" disabled style="opacity: 0.5; cursor: not-allowed;" title="<%= locale === 'ar' ? 'لا يوجد ملف صوتي' : 'No audio file' %>">
        <svg class="play-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
      </button>
    <% } %>
    <div class="lecture-secondary-actions">
      <a href="/download/<%= lecture._id %>" class="btn-download" title="<%= typeof t === 'function' ? t('lecture_download') : (locale === 'ar' ? 'تحميل' : 'Download') %>">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
      </a>
      <% const shareTitle = locale === 'ar' ? (lecture.titleArabic || '') : (lecture.titleEnglish || lecture.titleArabic || ''); %>
      <button class="btn-share-card" onclick="if(window.shareModule){window.shareModule.share(window.location.origin + '/lectures/<%= lecture.shortId ? lecture.shortId + '/' + (lecture.slug_en || '') + '/' + encodeURIComponent(lecture.slug_ar || '') : (lecture.slug ? encodeURIComponent(lecture.slug) : lecture._id) %>', '<%= shareTitle.replace(/'/g, "\\'").replace(/\n/g, " ") %>')}" title="<%= typeof t === 'function' ? t('lecture_share') : (locale === 'ar' ? 'مشاركة' : 'Share') %>">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="18" cy="5" r="3"></circle>
          <circle cx="6" cy="12" r="3"></circle>
          <circle cx="18" cy="19" r="3"></circle>
          <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
          <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
        </svg>
      </button>
    </div>
  </div>
</div>

<style>
  .lecture-card {
    background: white;
    border-radius: 12px;
    padding: 20px;
    display: flex;
    gap: 16px;
    align-items: center;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    max-width: 100%;
    box-sizing: border-box;
    overflow: hidden;
  }

  .lecture-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
  }

  .lecture-icon {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--accent-gold) 0%, var(--accent-amber) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--primary-dark);
  }

  .lecture-content {
    flex: 1;
    min-width: 0;
    max-width: 100%;
    overflow: hidden;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  .lecture-title {
    font-size: 18px;
    margin-bottom: 8px;
    font-weight: 600;
  }

  .lecture-title a {
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.3s;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  .lecture-title a:hover {
    color: var(--accent-gold);
  }

  .lecture-meta {
    color: var(--text-secondary);
    font-size: 14px;
    margin-bottom: 8px;
  }

  .lecture-sheikh {
    font-weight: 500;
    color: var(--accent-gold);
  }

  .lecture-info {
    color: var(--text-secondary);
    font-size: 13px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .lecture-divider {
    opacity: 0.5;
  }

  /* Number badge inside card - hidden on desktop, shown on mobile */
  .lecture-number-inside {
    display: none;
  }

  .lecture-secondary-actions {
    display: contents;
  }

  .lecture-category {
    background: #f0f0f0;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 12px;
  }

  .lecture-actions {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }

  .btn-play,
  .btn-download {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    text-decoration: none;
    font-size: 16px;
    transition: all 0.3s;
    border: 2px solid var(--accent-gold);
    cursor: pointer;
  }

  .btn-play {
    background: var(--accent-gold);
    color: var(--primary-dark);
  }

  .btn-play:hover {
    background: var(--accent-amber);
    transform: scale(1.05);
  }

  .btn-download {
    background: transparent;
    color: var(--accent-gold);
  }

  .btn-download:hover {
    background: var(--accent-gold);
    color: var(--primary-dark);
  }

  .btn-share-card {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    font-size: 16px;
    transition: all 0.3s;
    border: 2px solid var(--accent-gold);
    cursor: pointer;
    background: transparent;
    color: var(--accent-gold);
  }

  .btn-share-card:hover {
    background: var(--accent-gold);
    color: var(--primary-dark);
  }

  /* Tablet and below */
  @media (max-width: 768px) {
    .lecture-card {
      padding: 16px;
      gap: 12px;
    }

    .lecture-icon {
      width: 44px;
      height: 44px;
    }

    .lecture-title {
      font-size: 16px;
    }
  }

  /* Mobile redesign - matches design handoff */
  @media (max-width: 768px) {
    .lecture-card {
      flex-direction: column;
      align-items: stretch;
      width: 100%;
      padding: 14px;
      gap: 10px;
      border: 1px solid var(--redesign-gold-light, #DEC99A);
      border-radius: 10px;
      position: relative;
    }

    .lecture-icon {
      display: none;
    }

    /* Number badge inside card - top right corner */
    .lecture-number-inside {
      display: flex;
      position: absolute;
      top: 12px;
      right: 12px;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: var(--redesign-gold-primary, #C49A3C);
      color: var(--redesign-brown-dark, #2C1508);
      font-size: 14px;
      font-weight: 700;
      align-items: center;
      justify-content: center;
      font-family: var(--font-cairo, 'Cairo', sans-serif);
    }

    .lecture-number-inside:empty {
      display: none;
    }

    /* Hide sheikh/series meta on mobile - shown in series context */
    .lecture-meta {
      display: none;
    }

    .lecture-content {
      width: 100%;
    }

    .lecture-title {
      font-size: 15px;
      line-height: 1.5;
      margin-bottom: 6px;
      padding-left: 50px; /* Space for number badge */
    }

    html[dir="rtl"] .lecture-title {
      padding-left: 0;
      padding-right: 50px;
    }

    .lecture-info {
      font-size: 12px;
      color: var(--redesign-text-muted, #A89070);
      gap: 6px;
    }

    .lecture-divider {
      display: inline;
    }

    /* Actions: Play button full-width, download/share small */
    .lecture-actions {
      flex-direction: column;
      gap: 8px;
      width: 100%;
    }

    .btn-play {
      width: 100%;
      height: 42px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: var(--redesign-gold-primary, #C49A3C);
      border-color: var(--redesign-gold-primary, #C49A3C);
    }

    .btn-play::after {
      content: 'تشغيل';
      font-family: var(--font-cairo, 'Cairo', sans-serif);
    }

    html[dir="ltr"] .btn-play::after {
      content: 'Play';
    }

    .lecture-secondary-actions {
      display: flex;
      gap: 8px;
      justify-content: flex-end;
    }

    .btn-download,
    .btn-share-card {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      background: transparent;
      border: 1px solid var(--redesign-gold-light, #DEC99A);
      color: var(--redesign-text-mid, #7A5C3A);
    }

    .btn-download:hover,
    .btn-share-card:hover {
      background: var(--redesign-badge-bg, #E8D5A0);
      border-color: var(--redesign-gold-primary, #C49A3C);
    }
  }

  /* Small phones (below 480px) */
  @media (max-width: 480px) {
    .lecture-card {
      padding: 12px;
    }

    .lecture-number-inside {
      top: 10px;
      right: 10px;
      width: 28px;
      height: 28px;
      font-size: 12px;
    }

    .lecture-title {
      font-size: 14px;
      padding-left: 40px;
    }

    html[dir="rtl"] .lecture-title {
      padding-left: 0;
      padding-right: 40px;
    }

    .lecture-info {
      font-size: 11px;
    }

    .btn-play {
      height: 38px;
      font-size: 13px;
    }

    .btn-download,
    .btn-share-card {
      width: 32px;
      height: 32px;
    }
  }

  /* Very small phones (below 360px) */
  @media (max-width: 360px) {
    .lecture-card {
      padding: 10px;
    }

    .lecture-number-inside {
      top: 8px;
      right: 8px;
      width: 26px;
      height: 26px;
      font-size: 11px;
    }

    .lecture-title {
      font-size: 13px;
      padding-left: 36px;
    }

    html[dir="rtl"] .lecture-title {
      padding-left: 0;
      padding-right: 36px;
    }

    .lecture-info {
      font-size: 10px;
    }

    .btn-play {
      height: 36px;
      font-size: 12px;
    }

    .btn-download,
    .btn-share-card {
      width: 30px;
      height: 30px;
    }
  }
</style>
