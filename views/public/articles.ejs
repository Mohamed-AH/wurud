<style>
  .articles-page {
    min-height: 100vh;
    padding-bottom: 90px;
  }

  @media (max-width: 768px) {
    .articles-page {
      padding-bottom: calc(80px + env(safe-area-inset-bottom, 0));
    }
  }

  .articles-header {
    background: #2C1508;
    padding: 14px 16px 18px;
    text-align: center;
  }

  .articles-header h1 {
    color: #FDF8F2;
    font-size: 18px;
    font-weight: 800;
    margin: 0;
  }

  .articles-header p {
    color: #DEC99A;
    font-size: 11px;
    margin-top: 4px;
  }

  .articles-search {
    background: #F5EDE0;
    padding: 10px 14px;
    border-bottom: 1px solid #DEC99A;
  }

  .articles-search-wrapper {
    background: #FDF8F2;
    border: 1px solid #DEC99A;
    border-radius: 10px;
    display: flex;
    align-items: center;
    padding: 0 10px;
    gap: 8px;
  }

  .articles-search-icon {
    flex-shrink: 0;
    color: #A89070;
  }

  .articles-search-input {
    flex: 1;
    background: transparent;
    border: none;
    padding: 9px 0;
    font-family: inherit;
    font-size: 13px;
    color: #2C1508;
  }

  .articles-search-input::placeholder {
    color: #A89070;
  }

  .articles-search-input:focus {
    outline: none;
  }

  .articles-search-wrapper:focus-within {
    border-color: #C49A3C;
  }

  .articles-list {
    padding: 12px 14px;
    max-width: 900px;
    margin: 0 auto;
  }

  .article-card {
    background: #FDF8F2;
    border: 1px solid #DEC99A;
    border-radius: 12px;
    padding: 12px 14px;
    margin-bottom: 10px;
    text-decoration: none;
    display: block;
    transition: all 0.3s ease;
  }

  .article-card:hover {
    border-color: #C49A3C;
    box-shadow: 0 4px 16px rgba(44, 21, 8, 0.1);
    transform: translateY(-2px);
  }

  .article-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }

  .article-type {
    background: #E8D5A0;
    color: #7A5C3A;
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 8px;
  }

  .article-type.telegram {
    background: #6B7A4E;
    color: #FDF8F2;
  }

  .article-date {
    color: #A89070;
    font-size: 12px;
  }

  .article-title {
    color: #2C1508;
    font-size: 14px;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 5px;
    direction: rtl;
    text-align: right;
  }

  .article-summary {
    color: #7A5C3A;
    font-size: 12px;
    line-height: 1.55;
    margin-bottom: 8px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    direction: rtl;
    text-align: right;
  }

  .article-read-more {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 3px;
    color: #C49A3C;
    font-size: 11px;
    font-weight: 600;
  }

  /* LTR UI adjustments - keep Arabic content RTL */
  html[dir="ltr"] .article-card {
    text-align: left;
  }

  html[dir="ltr"] .article-meta {
    flex-direction: row-reverse;
  }

  html[dir="ltr"] .article-read-more {
    flex-direction: row-reverse;
  }

  html[dir="ltr"] .article-read-more .arrow {
    transform: scaleX(-1);
  }

  .pagination {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 8px;
    padding: 20px;
    max-width: 100%;
  }

  .pagination a,
  .pagination span {
    display: inline-block;
    padding: 6px 10px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
    min-width: 36px;
    text-align: center;
  }

  @media (max-width: 480px) {
    .pagination {
      gap: 4px;
      padding: 16px 12px;
    }

    .pagination a,
    .pagination span {
      padding: 5px 8px;
      font-size: 12px;
      min-width: 32px;
    }
  }

  .pagination a {
    background: #FDF8F2;
    color: #7A5C3A;
    border: 1px solid #DEC99A;
  }

  .pagination a:hover {
    background: #E8D5A0;
    border-color: #C49A3C;
  }

  .pagination .active {
    background: #C49A3C;
    color: #FDF8F2;
    border: 1px solid #C49A3C;
  }

  .pagination .disabled {
    background: #F5EDE0;
    color: #A89070;
    border: 1px solid #DEC99A;
    cursor: not-allowed;
  }

  .empty-state {
    text-align: center;
    padding: 60px 20px;
    color: #A89070;
  }

  .empty-icon {
    font-size: 48px;
    margin-bottom: 12px;
    opacity: 0.5;
  }

  .empty-title {
    font-size: 18px;
    font-weight: 600;
    color: #7A5C3A;
  }

  @media (max-width: 480px) {
    .articles-list {
      padding: 10px 12px;
    }

    .article-card {
      padding: 10px 12px;
    }

    .article-title {
      font-size: 13px;
    }

    .article-summary {
      font-size: 11px;
    }
  }
</style>

<div class="articles-page">
<div class="articles-header">
  <h1><%= locale === 'ar' ? 'المقالات' : 'Articles' %></h1>
  <p><%= locale === 'ar' ? 'مقالات ومواضيع علمية مختارة' : 'Selected scholarly articles and topics' %></p>
</div>

<div class="articles-search">
  <div class="articles-search-wrapper">
    <svg class="articles-search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
      <circle cx="11" cy="11" r="8"/>
      <line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>
    <input type="text" class="articles-search-input" placeholder="<%= locale === 'ar' ? 'ابحث في المقالات...' : 'Search articles...' %>" id="articleSearch" />
  </div>
</div>

<div class="articles-list" id="articlesList">
  <% if (articles && articles.length > 0) { %>
    <% articles.forEach(article => { %>
      <a href="/articles/<%= article.slug || article.shortId || article._id %>" class="article-card" data-title="<%= article.title %>">
        <div class="article-meta">
          <span class="article-type <%= article.type === 'TelegramArticle' ? 'telegram' : '' %>">
            <%= article.type === 'TelegramArticle' ? 'تليجرام' : 'أصداء' %>
          </span>
          <span class="article-date">
            <%
              const pubDate = new Date(article.publishedAt);
              const hijriFormatter = new Intl.DateTimeFormat('ar-SA-u-ca-islamic', {
                day: 'numeric',
                month: 'long',
                year: 'numeric'
              });
            %>
            <%= hijriFormatter.format(pubDate) %>
          </span>
        </div>
        <h3 class="article-title"><%= article.title %></h3>
        <% if (article.summary) { %>
          <p class="article-summary"><%= article.summary %></p>
        <% } %>
        <div class="article-read-more">
          <span><%= locale === 'ar' ? 'قراءة المقال' : 'Read Article' %></span>
          <span class="arrow">←</span>
        </div>
      </a>
    <% }); %>
  <% } else { %>
    <div class="empty-state">
      <div class="empty-icon">📝</div>
      <div class="empty-title"><%= locale === 'ar' ? 'لا توجد مقالات حالياً' : 'No articles yet' %></div>
    </div>
  <% } %>
</div>

<% if (totalPages > 1) { %>
  <div class="pagination">
    <% if (currentPage > 1) { %>
      <a href="/articles?page=<%= currentPage - 1 %>">←</a>
    <% } else { %>
      <span class="disabled">←</span>
    <% } %>

    <% for (let i = 1; i <= totalPages; i++) { %>
      <% if (i === currentPage) { %>
        <span class="active"><%= i %></span>
      <% } else { %>
        <a href="/articles?page=<%= i %>"><%= i %></a>
      <% } %>
    <% } %>

    <% if (currentPage < totalPages) { %>
      <a href="/articles?page=<%= currentPage + 1 %>">→</a>
    <% } else { %>
      <span class="disabled">→</span>
    <% } %>
  </div>
<% } %>
</div>

<script>
  const searchInput = document.getElementById('articleSearch');
  const articlesList = document.getElementById('articlesList');
  const articleCards = articlesList.querySelectorAll('.article-card');

  searchInput.addEventListener('input', function() {
    const query = this.value.toLowerCase().trim();

    articleCards.forEach(card => {
      const title = card.dataset.title.toLowerCase();
      if (query === '' || title.includes(query)) {
        card.style.display = 'block';
      } else {
        card.style.display = 'none';
      }
    });
  });
</script>
