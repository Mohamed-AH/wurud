    <% if ((typeof totalLectureCount !== 'undefined' && totalLectureCount > 0) && (typeof totalArticleCount !== 'undefined' && totalArticleCount > 0)) { %>
    <span class="stat-divider"></span>
    <% } %>
    <% if (typeof totalArticleCount !== 'undefined' && totalArticleCount > 0) { %>
    <div class="stat-item">
      <span class="stat-icon"><i data-lucide="pen-line"></i></span>
      <span class="stat-number"><%= totalArticleCount %></span>
