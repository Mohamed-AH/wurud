<!-- Search Hero -->
<div class="search-hero">
  <div class="search-hero-quote">
    <%= locale === 'ar'
      ? 'البحث في التفريغ الصوتي'
      : 'Search Audio Transcripts'
    %>
  </div>
  <div class="search-hero-subheading">
    <%= locale === 'ar'
      ? 'من الكلمة المكتوبة إلى اللحظة المسموعة.. طريقك الأقصر لضبط المسائل وتحرير الفوائد'
      : 'From written word to audio moment... your shortest path to precise Islamic scholarship'
    %>
  </div>
  <div class="search-container">
    <input
      type="text"
      class="search-input"
      id="searchInput"
      placeholder="<%= locale === 'ar' ? 'ابحث في نصوص الدروس...' : 'Search lecture transcripts...' %>"
    >
    <button type="button" class="search-btn" onclick="performSearch()">
      <%= locale === 'ar' ? 'بحث' : 'Search' %>
