<!-- Weekly Schedule Section -->
<% if (typeof homepageConfig === 'undefined' || homepageConfig.showSchedule !== false) { %>
<% if (typeof weeklySchedule !== 'undefined' && weeklySchedule && weeklySchedule.length > 0) { %>
<%
  // Split schedule into in-person and online
  const inPersonSchedule = weeklySchedule.filter(item => !item.location.includes('بُعد') && !item.location.includes('بعد'));
  const onlineSchedule = weeklySchedule.filter(item => item.location.includes('بُعد') || item.location.includes('بعد'));

  // Day translations - Arabic to English
  const dayTranslations = {
    'يومي': 'Daily', 'السبت': 'Saturday', 'الأحد': 'Sunday', 'الاثنين': 'Monday',
    'الثلاثاء': 'Tuesday', 'الأربعاء': 'Wednesday', 'الخميس': 'Thursday', 'الجمعة': 'Friday'
  };

  // Day abbreviations for mobile (Arabic)
  const dayShortAr = {
    'يومي': 'يومي', 'السبت': 'سبت', 'الأحد': 'أحد', 'الاثنين': 'إثن', 'الثلاثاء': 'ثلا',
    'الأربعاء': 'أرب', 'الخميس': 'خمي', 'الجمعة': 'جمع'
  };

  // Day abbreviations for mobile (English)
  const dayShortEn = {
    'يومي': 'Daily', 'السبت': 'Sat', 'الأحد': 'Sun', 'الاثنين': 'Mon',
    'الثلاثاء': 'Tue', 'الأربعاء': 'Wed', 'الخميس': 'Thu', 'الجمعة': 'Fri'
  };

  // Time translations for English
  const translateTime = (time) => {
    if (locale === 'en') {
      return time
        .replace('بعد صلاة الفجر', 'After Fajr')
        .replace('بعد صلاة الظهر', 'After Dhuhr')
        .replace('بعد صلاة العصر', 'After Asr')
        .replace('بعد صلاة المغرب', 'After Maghrib')
        .replace('بعد صلاة العشاء', 'After Isha')
        .replace('خطبة الجمعة', 'Friday Khutbah')
        .replace('الساعة ', '');
    }
    return time;
  };

  // Time abbreviations
  const timeShort = (time) => {
    if (locale === 'en') {
      return translateTime(time);
    }
    return time.replace('بعد صلاة ', '').replace('الساعة ', '').replace('خطبة ', '');
  };

  // Get day for display
  const getDay = (day) => locale === 'en' ? (dayTranslations[day] || day) : day;
  const getDayShort = (day) => locale === 'en' ? (dayShortEn[day] || day) : (dayShortAr[day] || day);

  // Group schedule items by series + location (regardless of time)
  const groupScheduleItems = (items) => {
    const dayOrder = ['السبت', 'الأحد', 'الاثنين', 'الثلاثاء', 'الأربعاء', 'الخميس', 'الجمعة'];
    const groups = {};

    items.forEach(item => {
      // Group by series + location only (not time)
      const key = `${item.seriesId._id}-${item.location}`;
      if (!groups[key]) {
        groups[key] = {
          ...item,
          dayTimes: [{ day: item.dayOfWeek, time: item.time }],
          days: [item.dayOfWeek]
        };
      } else {
        groups[key].dayTimes.push({ day: item.dayOfWeek, time: item.time });
        groups[key].days.push(item.dayOfWeek);
        // Keep the "newest" isNew flag
        if (item.isNew) groups[key].isNew = true;
        // Keep highest lecture count
        if (item.lectureCount > (groups[key].lectureCount || 0)) {
          groups[key].lectureCount = item.lectureCount;
          groups[key].latestLecture = item.latestLecture;
        }
      }
    });

    // Sort days within each group and determine if times vary
    return Object.values(groups).map(group => {
      // Sort dayTimes by day order
      group.dayTimes.sort((a, b) => dayOrder.indexOf(a.day) - dayOrder.indexOf(b.day));
      group.days.sort((a, b) => dayOrder.indexOf(a) - dayOrder.indexOf(b));

      // Check if all times are the same
      const uniqueTimes = new Set(group.dayTimes.map(dt => dt.time));
      group.hasVaryingTimes = uniqueTimes.size > 1;

      // If all times same, keep the single time value
      if (!group.hasVaryingTimes) {
        group.time = group.dayTimes[0].time;
      }

      return group;
    }).sort((a, b) => dayOrder.indexOf(a.days[0]) - dayOrder.indexOf(b.days[0]));
  };

  // Format combined days for display
  const formatDays = (days, short = false) => {
    const getDayFn = short ? getDayShort : getDay;
    const dayNames = days.map(d => getDayFn(d));

    if (dayNames.length === 1) return dayNames[0];
    if (dayNames.length === 2) {
      return locale === 'ar'
        ? `${dayNames[0]} و${dayNames[1]}`
        : `${dayNames[0]} & ${dayNames[1]}`;
    }
    // 3+ days
    const last = dayNames.pop();
    return locale === 'ar'
      ? `${dayNames.join('، ')} و${last}`
      : `${dayNames.join(', ')} & ${last}`;
  };

  // Create grouped schedules
  const groupedInPerson = groupScheduleItems(inPersonSchedule);
  const groupedOnline = groupScheduleItems(onlineSchedule);
%>
<%
  // Group schedule items by day for card display
  const dayOrderList = ['السبت', 'الأحد', 'الاثنين', 'الثلاثاء', 'الأربعاء', 'الخميس', 'الجمعة'];

  const groupByDay = (items) => {
    const byDay = {};
    dayOrderList.forEach(day => { byDay[day] = []; });

    items.forEach(item => {
      item.days.forEach(day => {
        if (byDay[day]) {
          byDay[day].push({
            ...item,
            displayTime: item.hasVaryingTimes
              ? translateTime(item.dayTimes.find(dt => dt.day === day)?.time || item.time)
              : translateTime(item.time)
          });
        }
      });
    });

    return byDay;
  };

  const inPersonByDay = groupByDay(groupedInPerson);
  const onlineByDay = groupByDay(groupedOnline);

  const getDayCount = (byDay) => {
    const counts = {};
    dayOrderList.forEach(day => { counts[day] = byDay[day].length; });
    return counts;
  };

  const inPersonCounts = getDayCount(inPersonByDay);
  const onlineCounts = getDayCount(onlineByDay);

  // Find first day with sessions for default tab
  const getFirstActiveDay = (counts) => {
    for (const day of dayOrderList) {
      if (counts[day] > 0) return day;
    }
    return dayOrderList[0];
  };
