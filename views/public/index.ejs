<!-- Weekly Schedule Section -->
<% if (typeof homepageConfig === 'undefined' || homepageConfig.showSchedule !== false) { %>
<% if (typeof weeklySchedule !== 'undefined' && weeklySchedule && weeklySchedule.length > 0) { %>
<%
  // Split schedule into in-person and online
  const inPersonSchedule = weeklySchedule.filter(item => !item.location.includes('بُعد') && !item.location.includes('بعد'));
  const onlineSchedule = weeklySchedule.filter(item => item.location.includes('بُعد') || item.location.includes('بعد'));

  // Day translations - Arabic to English
  const dayTranslations = {
    'يومي': 'Daily', 'السبت': 'Saturday', 'الأحد': 'Sunday', 'الاثنين': 'Monday',
    'الثلاثاء': 'Tuesday', 'الأربعاء': 'Wednesday', 'الخميس': 'Thursday', 'الجمعة': 'Friday'
  };

  // Day abbreviations for mobile (Arabic)
  const dayShortAr = {
    'يومي': 'يومي', 'السبت': 'سبت', 'الأحد': 'أحد', 'الاثنين': 'إثن', 'الثلاثاء': 'ثلا',
    'الأربعاء': 'أرب', 'الخميس': 'خمي', 'الجمعة': 'جمع'
  };

  // Day abbreviations for mobile (English)
  const dayShortEn = {
    'يومي': 'Daily', 'السبت': 'Sat', 'الأحد': 'Sun', 'الاثنين': 'Mon',
    'الثلاثاء': 'Tue', 'الأربعاء': 'Wed', 'الخميس': 'Thu', 'الجمعة': 'Fri'
  };

  // Time translations for English
  const translateTime = (time) => {
    if (locale === 'en') {
      return time
        .replace('بعد صلاة الفجر', 'After Fajr')
        .replace('بعد صلاة الظهر', 'After Dhuhr')
        .replace('بعد صلاة العصر', 'After Asr')
        .replace('بعد صلاة المغرب', 'After Maghrib')
        .replace('بعد صلاة العشاء', 'After Isha')
        .replace('خطبة الجمعة', 'Friday Khutbah')
        .replace('الساعة ', '');
    }
    return time;
  };

  // Time abbreviations
  const timeShort = (time) => {
    if (locale === 'en') {
      return translateTime(time);
    }
    return time.replace('بعد صلاة ', '').replace('الساعة ', '').replace('خطبة ', '');
  };

  // Get day for display
  const getDay = (day) => locale === 'en' ? (dayTranslations[day] || day) : day;
  const getDayShort = (day) => locale === 'en' ? (dayShortEn[day] || day) : (dayShortAr[day] || day);

  // Group schedule items by series + time + location
  const groupScheduleItems = (items) => {
    const dayOrder = ['السبت', 'الأحد', 'الاثنين', 'الثلاثاء', 'الأربعاء', 'الخميس', 'الجمعة'];
    const groups = {};

    items.forEach(item => {
      const key = `${item.seriesId._id}-${item.time}-${item.location}`;
      if (!groups[key]) {
        groups[key] = {
          ...item,
          days: [item.dayOfWeek]
        };
      } else {
        groups[key].days.push(item.dayOfWeek);
        // Keep the "newest" isNew flag
        if (item.isNew) groups[key].isNew = true;
      }
    });

    // Sort days within each group and sort groups by first day
    return Object.values(groups).map(group => {
      group.days.sort((a, b) => dayOrder.indexOf(a) - dayOrder.indexOf(b));
      return group;
    }).sort((a, b) => dayOrder.indexOf(a.days[0]) - dayOrder.indexOf(b.days[0]));
  };

  // Format combined days for display
  const formatDays = (days, short = false) => {
    const getDayFn = short ? getDayShort : getDay;
    const dayNames = days.map(d => getDayFn(d));

    if (dayNames.length === 1) return dayNames[0];
    if (dayNames.length === 2) {
      return locale === 'ar'
        ? `${dayNames[0]} و${dayNames[1]}`
        : `${dayNames[0]} & ${dayNames[1]}`;
    }
    // 3+ days
    const last = dayNames.pop();
    return locale === 'ar'
      ? `${dayNames.join('، ')} و${last}`
      : `${dayNames.join(', ')} & ${last}`;
  };

  // Create grouped schedules
  const groupedInPerson = groupScheduleItems(inPersonSchedule);
  const groupedOnline = groupScheduleItems(onlineSchedule);
%>
<section class="weekly-schedule-section">
  <div class="schedule-header">
    <h2 class="schedule-title">
      📅 <%= locale === 'ar' ? 'جدول الدروس الأسبوعي' : 'Weekly Class Schedule' %>
    </h2>
  </div>

  <div class="schedule-tabs">
    <button class="schedule-tab active" onclick="switchScheduleTab('inperson')">
      🕌 <%= locale === 'ar' ? 'جامع الورود' : 'In-Person' %>
      <span class="schedule-tab-count"><%= groupedInPerson.length %></span>
    </button>
    <button class="schedule-tab" onclick="switchScheduleTab('online')">
      💻 <%= locale === 'ar' ? 'عن بُعد' : 'Online' %>
      <span class="schedule-tab-count"><%= groupedOnline.length %></span>
    </button>
  </div>

  <!-- In-Person Classes Panel -->
  <div id="schedule-inperson" class="schedule-panel active">
    <% if (groupedInPerson.length > 0) { %>
    <div class="schedule-table-wrapper">
      <table class="schedule-table">
        <thead>
          <tr>
            <th><%= locale === 'ar' ? 'اليوم' : 'Day' %></th>
            <th><%= locale === 'ar' ? 'الوقت' : 'Time' %></th>
            <th><%= locale === 'ar' ? 'السلسلة' : 'Series' %></th>
            <th><%= locale === 'ar' ? 'الدرس #' : 'Lesson #' %></th>
          </tr>
        </thead>
        <tbody>
          <% groupedInPerson.forEach(function(item) { %>
          <tr>
            <td class="schedule-day-cell<%= item.days.length > 1 ? ' multi-day' : '' %>">
              <span class="day-full"><%= formatDays(item.days, false) %></span>
              <span class="day-short"><%= formatDays(item.days, true) %></span>
            </td>
            <td class="schedule-time-cell">
              <span class="time-full"><%= translateTime(item.time) %></span>
              <span class="time-short"><%= timeShort(item.time) %></span>
            </td>
            <td class="schedule-series-cell">
              <% if (item.isNew) { %><span class="new-badge"><%= locale === 'ar' ? 'جديد' : 'NEW' %></span><% } %>
              <a href="/series/<%= item.seriesId.slug ? encodeURIComponent(item.seriesId.slug) : item.seriesId._id %>">
                <%= locale === 'ar' ? item.seriesId.titleArabic : (item.seriesId.titleEnglish || item.seriesId.titleArabic) %>
              </a>
            </td>
            <td style="text-align: center;">
              <% if (item.latestLecture && item.latestLecture.lectureNumber) { %>
              <a href="/lectures/<%= item.latestLecture.slug ? encodeURIComponent(item.latestLecture.slug) : item.latestLecture._id %>" style="text-decoration: none;">
                <span class="schedule-lesson-num"><%= item.latestLecture.lectureNumber %></span>
              </a>
              <% } else if (item.lectureCount > 0) { %>
              <a href="/series/<%= item.seriesId.slug ? encodeURIComponent(item.seriesId.slug) : item.seriesId._id %>" style="text-decoration: none;">
                <span class="schedule-lesson-num"><%= item.lectureCount %></span>
              </a>
              <% } else { %>
              <span style="color: var(--text-muted);">-</span>
              <% } %>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <p style="text-align: center; color: var(--text-muted); padding: 24px;"><%= locale === 'ar' ? 'لا توجد دروس حضورية حالياً' : 'No in-person classes currently' %></p>
    <% } %>
  </div>

  <!-- Online Classes Panel -->
  <div id="schedule-online" class="schedule-panel">
    <% if (groupedOnline.length > 0) { %>
    <div class="schedule-table-wrapper">
      <table class="schedule-table">
        <thead>
          <tr>
            <th><%= locale === 'ar' ? 'اليوم' : 'Day' %></th>
            <th><%= locale === 'ar' ? 'الوقت' : 'Time' %></th>
            <th><%= locale === 'ar' ? 'السلسلة' : 'Series' %></th>
            <th><%= locale === 'ar' ? 'الدرس #' : 'Lesson #' %></th>
          </tr>
        </thead>
        <tbody>
          <% groupedOnline.forEach(function(item) { %>
          <tr>
            <td class="schedule-day-cell<%= item.days.length > 1 ? ' multi-day' : '' %>">
              <span class="day-full"><%= formatDays(item.days, false) %></span>
              <span class="day-short"><%= formatDays(item.days, true) %></span>
            </td>
            <td class="schedule-time-cell">
              <span class="time-full"><%= translateTime(item.time) %></span>
              <span class="time-short"><%= timeShort(item.time) %></span>
            </td>
            <td class="schedule-series-cell">
              <% if (item.isNew) { %><span class="new-badge"><%= locale === 'ar' ? 'جديد' : 'NEW' %></span><% } %>
              <a href="/series/<%= item.seriesId.slug ? encodeURIComponent(item.seriesId.slug) : item.seriesId._id %>">
                <%= locale === 'ar' ? item.seriesId.titleArabic : (item.seriesId.titleEnglish || item.seriesId.titleArabic) %>
              </a>
            </td>
            <td style="text-align: center;">
              <% if (item.latestLecture && item.latestLecture.lectureNumber) { %>
              <a href="/lectures/<%= item.latestLecture.slug ? encodeURIComponent(item.latestLecture.slug) : item.latestLecture._id %>" style="text-decoration: none;">
                <span class="schedule-lesson-num"><%= item.latestLecture.lectureNumber %></span>
              </a>
              <% } else if (item.lectureCount > 0) { %>
              <a href="/series/<%= item.seriesId.slug ? encodeURIComponent(item.seriesId.slug) : item.seriesId._id %>" style="text-decoration: none;">
                <span class="schedule-lesson-num"><%= item.lectureCount %></span>
              </a>
              <% } else { %>
              <span style="color: var(--text-muted);">-</span>
              <% } %>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <p style="text-align: center; color: var(--text-muted); padding: 24px;"><%= locale === 'ar' ? 'لا توجد دروس عن بُعد حالياً' : 'No online classes currently' %></p>
    <% } %>
  </div>
</section>

<script>
function switchScheduleTab(tab) {
  // Update tab buttons
  document.querySelectorAll('.schedule-tab').forEach(btn => btn.classList.remove('active'));
  event.target.closest('.schedule-tab').classList.add('active');

  // Update panels
  document.querySelectorAll('.schedule-panel').forEach(panel => panel.classList.remove('active'));
  document.getElementById('schedule-' + tab).classList.add('active');
}
</script>
<% } %>
<% } %>

<!-- Homepage Sections -->
<% if (typeof homepageSections !== 'undefined' && homepageSections && homepageSections.length > 0) { %>
<div class="homepage-sections">
  <% homepageSections.forEach(function(section) { %>
  <div class="section-block" id="section-<%= section.slug %>">
    <div class="section-header" onclick="toggleSection('<%= section.slug %>')">
      <div class="section-header-left">
        <span class="section-icon"><%= section.icon %></span>
        <h2 class="section-title"><%= locale === 'ar' ? section.title.ar : section.title.en %></h2>
        <span class="section-count"><%= section.totalSeriesCount %></span>
      </div>
      <button class="section-toggle <%= section.collapsedByDefault ? 'collapsed' : '' %>" id="toggle-<%= section.slug %>" aria-label="Toggle">&#9650;</button>
    </div>
    <div class="section-content <%= section.collapsedByDefault ? 'collapsed' : '' %>" id="content-<%= section.slug %>">
      <table class="section-table">
        <% const visibleSeries = section.series.slice(0, section.maxVisible || 5); %>
        <% const hiddenSeries = section.series.slice(section.maxVisible || 5); %>
        <% visibleSeries.forEach(function(s) { %>
        <tr>
          <td style="width:60%">
            <a href="/series/<%= s.slug %>" class="section-series-title"><%= locale === 'ar' ? s.titleArabic : (s.titleEnglish || s.titleArabic) %></a>
            <% if (locale === 'en' && s.titleArabic) { %>
              <div class="section-series-subtitle"><%= s.titleArabic %></div>
            <% } %>
          </td>
          <td class="hide-mobile" style="width:20%">
            <% if (s.sheikh) { %>
              <span style="color:#666;font-size:14px;"><%= locale === 'ar' ? s.sheikh.nameArabic : (s.sheikh.nameEnglish || s.sheikh.nameArabic) %></span>
            <% } %>
          </td>
          <td style="width:10%;text-align:center;">
            <span class="section-lecture-count"><%= s.lectureCount %> <%= locale === 'ar' ? 'درس' : '' %></span>
          </td>
          <td class="hide-mobile" style="width:10%;text-align:center;">
            <a href="/series/<%= s.slug %>" class="section-view-btn"><%= locale === 'ar' ? 'عرض' : 'View' %></a>
          </td>
        </tr>
        <% }) %>
        <% hiddenSeries.forEach(function(s) { %>
        <tr class="section-hidden-row" data-section="<%= section.slug %>" style="display:none;">
          <td style="width:60%">
            <a href="/series/<%= s.slug %>" class="section-series-title"><%= locale === 'ar' ? s.titleArabic : (s.titleEnglish || s.titleArabic) %></a>
            <% if (locale === 'en' && s.titleArabic) { %>
              <div class="section-series-subtitle"><%= s.titleArabic %></div>
            <% } %>
          </td>
          <td class="hide-mobile" style="width:20%">
            <% if (s.sheikh) { %>
              <span style="color:#666;font-size:14px;"><%= locale === 'ar' ? s.sheikh.nameArabic : (s.sheikh.nameEnglish || s.sheikh.nameArabic) %></span>
            <% } %>
          </td>
          <td style="width:10%;text-align:center;">
            <span class="section-lecture-count"><%= s.lectureCount %> <%= locale === 'ar' ? 'درس' : '' %></span>
          </td>
          <td class="hide-mobile" style="width:10%;text-align:center;">
            <a href="/series/<%= s.slug %>" class="section-view-btn"><%= locale === 'ar' ? 'عرض' : 'View' %></a>
          </td>
        </tr>
        <% }) %>
      </table>
      <% if (hiddenSeries.length > 0) { %>
        <button class="section-show-more" id="showmore-<%= section.slug %>" onclick="showMoreSeries('<%= section.slug %>')">
          <%= locale === 'ar' ? 'عرض المزيد' : 'Show more' %> (<%= hiddenSeries.length %>)
        </button>
      <% } %>
    </div>
  </div>
  <% }) %>
</div>

<script>
function toggleSection(slug) {
  const content = document.getElementById('content-' + slug);
  const toggle = document.getElementById('toggle-' + slug);
  content.classList.toggle('collapsed');
  toggle.classList.toggle('collapsed');
  // Persist state
  try {
    const state = JSON.parse(localStorage.getItem('sectionState') || '{}');
    state[slug] = content.classList.contains('collapsed');
    localStorage.setItem('sectionState', JSON.stringify(state));
  } catch(e) {}
}

function showMoreSeries(slug) {
  const rows = document.querySelectorAll('.section-hidden-row[data-section="' + slug + '"]');
  rows.forEach(row => row.style.display = '');
  const btn = document.getElementById('showmore-' + slug);
  if (btn) btn.style.display = 'none';
}

// Restore collapsed state from localStorage
(function() {
  try {
    const state = JSON.parse(localStorage.getItem('sectionState') || '{}');
    Object.keys(state).forEach(slug => {
      const content = document.getElementById('content-' + slug);
      const toggle = document.getElementById('toggle-' + slug);
      if (content && toggle) {
        if (state[slug]) {
          content.classList.add('collapsed');
          toggle.classList.add('collapsed');
        } else {
          content.classList.remove('collapsed');
          toggle.classList.remove('collapsed');
        }
      }
    });
  } catch(e) {}
})();
</script>
<% } %>

