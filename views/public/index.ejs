<style>
  /* Search Hero Section - Redesigned per design handoff */
  .search-hero {
    background: linear-gradient(to left, var(--redesign-brown-dark, #2C1508) 0%, #3D1E0A 28%, #5E6B3D 62%, var(--redesign-sage, #6B7A4E) 100%);
    padding: 64px 0 56px;
    text-align: center;
    position: relative;
  }

  .search-hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(to left, transparent 0%, var(--redesign-gold-primary, #C49A3C) 20%, var(--redesign-gold-primary, #C49A3C) 80%, transparent 100%);
  }

  /* Calligraphy watermark background */
  .search-hero::before {
    content: '﷽';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 200px;
    color: rgba(255, 255, 255, 0.02);
    font-family: var(--font-arabic-display);
    pointer-events: none;
    z-index: 0;
  }

  .search-hero > * {
    position: relative;
    z-index: 1;
  }

  .search-hero-quote {
    font-family: var(--font-cairo, 'Cairo', sans-serif);
    font-size: 38px;
    font-weight: 800;
    color: var(--redesign-card-bg, #FDF8F2);
    margin-bottom: 12px;
    line-height: 1.4;
  }

  .search-hero-subheading {
    font-family: var(--font-cairo, 'Cairo', sans-serif);
    font-size: 15px;
    font-weight: 400;
    color: rgba(245, 237, 224, 0.7);
    margin-bottom: 36px;
    line-height: 1.6;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .search-container {
    max-width: 580px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
  }

  .search-input {
    flex: 1;
    padding: 0 20px;
    height: 52px;
    border: none;
    border-radius: 0 10px 10px 0;
    font-family: var(--font-cairo, 'Cairo', sans-serif);
    font-size: 15px;
    background: var(--redesign-card-bg, #FDF8F2);
    color: var(--redesign-brown-dark, #2C1508);
    direction: rtl;
  }

  .search-input::placeholder {
    color: var(--redesign-text-muted, #A89070);
  }

  .search-input:focus {
    outline: none;
    box-shadow: 0 0 0 3px rgba(193, 154, 107, 0.3), 0 8px 24px rgba(92, 64, 51, 0.15);
  }

  .search-btn {
    padding: 0 28px;
    height: 52px;
    background: var(--redesign-gold-primary, #C49A3C);
    color: var(--redesign-card-bg, #FDF8F2);
    border: none;
    border-radius: 10px 0 0 10px;
    font-family: var(--font-cairo, 'Cairo', sans-serif);
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }

  .search-btn:hover {
    background: #B38A30;
  }

  /* Archive Stats Badge */
  .archive-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-top: 22px;
    flex-wrap: wrap;
  }

  .stat-item {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 10px 22px;
    background: rgba(20, 10, 4, 0.5);
    border: 1px solid rgba(196, 154, 60, 0.28);
    border-radius: 24px;
  }

  .stat-icon {
    color: var(--redesign-gold-light, #DEC99A);
    display: flex;
    align-items: center;
  }

  .stat-icon .lucide {
    width: 18px;
    height: 18px;
    stroke-width: 2;
  }

  .stat-number {
    font-family: var(--font-cairo, 'Cairo', sans-serif);
    font-size: 16px;
    font-weight: 700;
    color: var(--redesign-card-bg, #FDF8F2);
    direction: ltr;
  }

  .stat-label {
    font-family: var(--font-cairo, 'Cairo', sans-serif);
    font-size: 13px;
    font-weight: 400;
    color: rgba(245, 237, 224, 0.55);
  }

  .stat-divider {
    display: none;
  }

  /* Legacy support */
  .lecture-count-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 32px;
    padding: 20px 0;
  }

  .count-divider {
    width: 48px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(180, 150, 110, 0.6), transparent);
  }

  .count-text {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  .count-number {
    font-family: var(--font-arabic-display);
    font-size: 24px;
    font-weight: 600;
    color: rgba(250, 247, 242, 0.8);
    letter-spacing: 0.5px;
  }

  .count-label {
    font-family: var(--font-arabic-body);
    font-size: 15px;
    font-weight: 400;
    color: rgba(250, 247, 242, 0.8);
    letter-spacing: 0.3px;
  }

  /* Filter Panel - Redesigned per design handoff */
  .filters-section {
    max-width: 960px;
    margin: 0 auto;
    padding: 16px 20px 14px;
    background: var(--redesign-card-bg, #FDF8F2);
    border: 1px solid var(--redesign-badge-bg, #E8D5A0);
    border-top: none;
  }

  .filter-group {
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .filter-group:last-child {
    margin-bottom: 0;
  }

  .filter-label {
    font-family: var(--font-cairo, 'Cairo', sans-serif);
    font-size: 12px;
    font-weight: 500;
    color: var(--redesign-text-muted, #A89070);
    min-width: 50px;
    flex-shrink: 0;
  }

  .filter-chips {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
  }

  .chip {
    padding: 4px 13px;
    border: none;
    border-radius: 3px;
    background: transparent;
    color: var(--redesign-text-mid, #7A5C3A);
    font-family: var(--font-cairo, 'Cairo', sans-serif);
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .chip:hover {
    background: var(--redesign-badge-bg, #E8D5A0);
  }

  .chip.active {
    background: var(--redesign-brown-dark, #2C1508);
    color: var(--redesign-gold-primary, #C49A3C);
    font-weight: 700;
  }

  .clear-filters-btn {
    padding: 4px 13px;
    border: none;
    border-radius: 3px;
    background: transparent;
    color: var(--redesign-text-muted, #A89070);
    font-family: var(--font-cairo, 'Cairo', sans-serif);
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s ease;
    text-decoration: underline;
  }

  .clear-filters-btn:hover {
    background: #dc3545;
    color: white;
  }

  /* Minimized Title/Name Search Section - Inside filter panel */
  .title-search-section {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .title-search-wrapper {
    position: relative;
    background: var(--redesign-cream-bg, #F5EDE0);
    border-radius: 6px;
    display: flex;
    align-items: center;
    padding: 0 12px;
    gap: 8px;
    margin-bottom: 14px;
  }

  .title-search-input {
    flex: 1;
    padding: 10px 0;
    border: none;
    font-family: var(--font-cairo, 'Cairo', sans-serif);
    font-size: 14px;
    background: transparent;
    color: var(--redesign-brown-dark, #2C1508);
    direction: rtl;
  }

  .title-search-input::placeholder {
    color: var(--redesign-text-muted, #A89070);
    font-size: 14px;
  }

  .title-search-input:focus {
    outline: none;
  }

  .title-search-icon {
    font-size: 14px;
    opacity: 0.6;
    cursor: pointer;
    transition: opacity 0.2s ease;
    order: -1;
  }

  .title-search-icon:hover {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .title-search-section {
      padding: 0 14px;
    }

    .title-search-wrapper {
      padding: 0 10px;
      gap: 6px;
      margin-bottom: 10px;
    }

    .title-search-input {
      font-size: 13px;
      padding: 9px 0;
    }

    /* Fix 1: Horizontal filter scroll */
    .filter-group {
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding-bottom: 4px;
    }
    .filter-group::-webkit-scrollbar {
      display: none;
    }
    .filter-chips {
      flex-wrap: nowrap;
      flex-shrink: 0;
    }
    .chip {
      flex-shrink: 0;
      white-space: nowrap;
    }
    .filters-section {
      padding: 12px 14px 10px;
    }
  }

  /* Series Cards/Rows */
  .series-list {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 32px var(--space-3xl);
  }

  /* Series Card - Redesigned per design handoff */
  .series-card {
    border-bottom: 1px solid #EDE4D3;
    margin-bottom: 0;
    padding: 18px 2px;
  }

  .series-card::before {
    display: none;
  }

  .series-card:hover {
    background: rgba(196, 154, 60, 0.03);
  }

  .series-header {
    display: flex;
    flex-direction: row-reverse;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    padding: 0;
    background: transparent;
    border: none;
  }

  .series-title {
    font-family: var(--font-cairo, 'Cairo', sans-serif);
    font-size: 15px;
    font-weight: 600;
    color: var(--redesign-brown-dark, #2C1508);
    margin: 0;
    line-height: 1.5;
    text-align: right;
    flex: 1;
  }

  .series-title a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .series-title a:hover {
    color: var(--redesign-gold-primary, #C49A3C);
  }

  .series-meta {
    display: none;
  }

  .series-author {
    display: none;
  }

  .series-author-label {
    display: none;
  }

  .series-sheikh {
    display: none;
  }

  .series-info {
    display: flex;
    gap: 8px;
    font-size: 11px;
    align-items: center;
    flex-shrink: 0;
  }

  .series-info > span:first-child {
    background: var(--redesign-badge-bg, #E8D5A0);
    color: var(--redesign-text-mid, #7A5C3A);
    font-weight: 700;
    padding: 3px 11px;
    border-radius: 10px;
    white-space: nowrap;
  }

  .series-info span:not(:last-child)::after {
    display: none;
  }

  .category-badge {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 600;
    background: var(--redesign-badge-bg, #E8D5A0);
    color: var(--redesign-text-mid, #7A5C3A);
    border: none;
  }

  .expand-btn {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    padding: 0;
    background: var(--redesign-card-bg, #FDF8F2);
    border: 1px solid var(--redesign-gold-light, #DEC99A);
    border-radius: 6px;
    color: var(--redesign-brown-dark, #2C1508);
    cursor: pointer;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .expand-btn .expand-icon {
    width: 18px;
    height: 18px;
    stroke-width: 2.5;
  }

  .expand-btn:hover {
    background: var(--redesign-badge-bg, #E8D5A0);
  }

  .expand-btn.expanded {
    background: var(--redesign-badge-bg, #E8D5A0);
  }

  /* Episodes List - CLS-safe animation approach */
  .episodes-list {
    background: var(--redesign-cream-bg, #F5EDE0);
    border-radius: 8px;
    margin-top: 16px;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease-out, opacity 0.2s ease-out;
    opacity: 0;
  }

  .episodes-list.show {
    max-height: 10000px;
    overflow: visible;
    opacity: 1;
    transition: max-height 0.5s ease-in, opacity 0.3s ease-in;
  }

  #content-khutbas .episodes-list.show {
    max-height: 10000px;
    overflow: visible;
    opacity: 1;
  }

  .episode-item {
    padding: 14px 16px;
    border-bottom: 1px solid var(--redesign-badge-bg, #E8D5A0);
    transition: background 0.15s ease;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .episode-item:last-child {
    border-bottom: none;
  }

  .episode-item:hover {
    background: rgba(196, 154, 60, 0.06);
  }

  .episode-header {
    display: flex;
    gap: 12px;
    align-items: center;
    flex: 1;
    min-width: 0;
  }

  .episode-number {
    width: 28px;
    height: 28px;
    background: var(--redesign-gold-primary, #C49A3C);
    color: var(--redesign-card-bg, #FDF8F2);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-cairo, 'Cairo', sans-serif);
    font-weight: 700;
    font-size: 13px;
    flex-shrink: 0;
  }

  .episode-title {
    font-family: var(--font-cairo, 'Cairo', sans-serif);
    font-size: 14px;
    font-weight: 600;
    color: var(--redesign-brown-dark, #2C1508);
    flex: 1;
    line-height: 1.5;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .episode-meta {
    display: none;
  }

  .episode-meta span:not(:last-child)::after {
    display: none;
  }

  .hijri-date {
    color: var(--redesign-text-mid, #7A5C3A);
    font-weight: 500;
  }

  .episode-actions {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }

  .btn-play, .btn-download {
    padding: 6px 14px;
    border-radius: 6px;
    font-family: var(--font-cairo, 'Cairo', sans-serif);
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    white-space: nowrap;
  }

  .btn-play {
    background: var(--redesign-gold-primary, #C49A3C);
    color: var(--redesign-card-bg, #FDF8F2);
    border: none;
  }

  .btn-play:hover {
    background: #B38A30;
  }

  .btn-download {
    background: transparent;
    border: 1px solid var(--redesign-gold-primary, #C49A3C);
    color: var(--redesign-gold-primary, #C49A3C);
  }

  .btn-download:hover {
    background: var(--redesign-gold-primary, #C49A3C);
    color: var(--redesign-card-bg, #FDF8F2);
  }

  .btn-play .lucide, .btn-download .lucide {
    width: 14px;
    height: 14px;
    stroke-width: 2;
  }

  /* General inline icons */
  .episode-meta .lucide,
  .hijri-date .lucide,
  .section-header .lucide,
  .schedule-section-header .lucide {
    width: 14px;
    height: 14px;
    margin-inline-end: 4px;
    vertical-align: -2px;
    stroke-width: 2;
  }

  /* Episode Sort Bar */
  .episode-sort-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: var(--redesign-card-bg, #FDF8F2);
    border-bottom: 1px solid var(--redesign-badge-bg, #E8D5A0);
  }

  .episode-sort-label {
    font-family: var(--font-cairo, 'Cairo', sans-serif);
    font-size: 12px;
    font-weight: 600;
    color: var(--redesign-text-muted, #A89070);
    white-space: nowrap;
  }

  .episode-sort-chips {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .sort-chip {
    padding: 5px 12px;
    border-radius: 6px;
    border: 1px solid var(--redesign-gold-light, #DEC99A);
    background: var(--redesign-card-bg, #FDF8F2);
    font-family: var(--font-cairo, 'Cairo', sans-serif);
    font-size: 11px;
    font-weight: 600;
    color: var(--redesign-text-mid, #7A5C3A);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .sort-chip:hover {
    background: var(--redesign-badge-bg, #E8D5A0);
  }

  .sort-chip.active {
    background: var(--redesign-gold-primary, #C49A3C);
    color: var(--redesign-card-bg, #FDF8F2);
    border-color: var(--redesign-gold-primary, #C49A3C);
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: var(--space-3xl);
    color: var(--text-muted);
  }

  .empty-icon {
    margin-bottom: var(--space-md);
    color: var(--redesign-text-muted, #A89070);
  }

  .empty-icon .lucide {
    width: 64px;
    height: 64px;
    stroke-width: 1;
  }

  .empty-title {
    font-family: var(--font-arabic-display);
    font-size: 24px;
    font-weight: 600;
    margin-bottom: var(--space-sm);
    color: var(--text-secondary);
  }

  .empty-text {
    font-size: 16px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .search-hero {
      min-height: 200px;
      padding: var(--space-lg) var(--space-md);
    }

    .search-hero-quote {
      font-size: 20px;
      margin-bottom: 10px;
      padding: 0 8px;
      word-wrap: break-word;
      overflow-wrap: break-word;
      line-height: 1.6;
    }

    .search-hero-subheading {
      font-size: 14px;
      margin-bottom: 20px;
      padding: 0 12px;
      line-height: 1.5;
    }

    .search-hero::before {
      font-size: 100px;
    }

    .search-container {
      flex-direction: column;
      padding: 0 8px;
    }

    .search-input,
    .search-btn {
      width: 100%;
      box-sizing: border-box;
    }

    .search-input {
      font-size: 16px;
      padding: 14px 16px;
    }

    .archive-stats {
      gap: 12px;
      margin-top: 20px;
      padding: 14px 0;
    }

    .stat-item {
      padding: 8px 14px;
    }

    .stat-number {
      font-size: 18px;
    }

    .stat-label {
      font-size: 12px;
    }

    .stat-divider {
      height: 28px;
    }

    .lecture-count-badge {
      margin-top: 20px;
      padding: 16px 0;
      gap: 12px;
    }

    .count-divider {
      width: 32px;
    }

    .count-text {
      gap: 8px;
    }

    .count-number {
      font-size: 20px;
    }

    .count-label {
      font-size: 13px;
    }

    .series-meta {
      flex-direction: column;
      align-items: flex-start;
    }

    .episode-item {
      padding: 10px 12px;
      gap: 8px;
    }

    .episode-number {
      width: 24px;
      height: 24px;
      font-size: 11px;
    }

    .episode-title {
      font-size: 13px;
    }

    .episode-actions {
      gap: 6px;
    }

    /* Fix 4: Icon-only buttons on mobile */
    .btn-play, .btn-download {
      padding: 8px;
      font-size: 0;
      gap: 0;
      width: 32px;
      height: 32px;
    }
    .btn-play .lucide, .btn-download .lucide {
      width: 16px;
      height: 16px;
    }

    /* Fix 3: Allow episode title to wrap */
    .episode-title {
      font-size: 13px;
      white-space: normal;
      overflow: visible;
      text-overflow: clip;
      line-height: 1.4;
    }
  }

  @media (max-width: 480px) {
    .episode-item {
      padding: 8px 10px;
    }

    .episode-header {
      gap: 8px;
    }

    .episode-number {
      width: 22px;
      height: 22px;
      font-size: 10px;
      border-radius: 5px;
    }

    .episode-title {
      font-size: 12px;
    }

    .btn-play, .btn-download {
      padding: 6px;
      width: 28px;
      height: 28px;
    }
    .btn-play .lucide, .btn-download .lucide {
      width: 14px;
      height: 14px;
    }
  }

  /* Homepage Sections - Redesigned per design handoff */
  .homepage-sections {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 32px 44px;
  }

  .section-block {
    background: transparent;
    border-radius: 12px;
    margin-bottom: 16px;
    overflow: hidden;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 20px;
    background: var(--redesign-badge-bg, #E8D5A0);
    cursor: pointer;
    user-select: none;
    border-radius: 12px 12px 0 0;
  }

  .section-header:hover {
    background: #DCC890;
  }

  .section-header-left {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-direction: row-reverse;
  }

  .section-icon {
    font-size: 18px;
  }

  .section-title {
    font-family: var(--font-cairo, 'Cairo', sans-serif);
    font-size: 18px;
    font-weight: 800;
    color: var(--redesign-brown-dark, #2C1508);
    margin: 0;
  }

  .section-count {
    font-size: 12px;
    font-weight: 700;
    color: var(--redesign-gold-primary, #C49A3C);
    background: var(--redesign-brown-dark, #2C1508);
    padding: 3px 12px;
    border-radius: 10px;
  }

  .section-toggle {
    background: none;
    border: none;
    font-size: 18px;
    color: var(--redesign-text-mid, #7A5C3A);
    cursor: pointer;
    padding: 4px 8px;
    transition: transform 0.2s ease;
  }

  .section-toggle.collapsed {
    transform: rotate(180deg);
  }

  .section-content {
    transition: max-height 0.3s ease, opacity 0.2s ease;
    overflow: hidden;
    background: var(--redesign-card-bg, #FDF8F2);
    border: 1px solid var(--redesign-gold-light, #DEC99A);
    border-top: none;
    border-radius: 0 0 12px 12px;
  }

  .section-content.collapsed {
    max-height: 0 !important;
    opacity: 0;
    border: none;
  }

  .section-table {
    width: 100%;
    border-collapse: collapse;
  }

  .section-table tr {
    border-bottom: 1px solid #F0E5CC;
    transition: background 0.15s;
  }

  .section-table tr:last-child {
    border-bottom: none;
  }

  .section-table tr:hover {
    background: rgba(196, 154, 60, 0.05);
  }

  .section-table td {
    padding: 14px 20px;
    vertical-align: middle;
  }

  .section-series-title {
    font-family: var(--font-cairo, 'Cairo', sans-serif);
    font-size: 15px;
    font-weight: 600;
    color: var(--redesign-brown-dark, #2C1508);
    text-decoration: none;
    display: block;
  }

  .section-series-title:hover {
    color: var(--redesign-gold-primary, #C49A3C);
  }

  .section-series-subtitle {
    font-size: 12px;
    color: var(--redesign-text-muted, #A89070);
    margin-top: 2px;
  }

  .section-lecture-count {
    display: inline-block;
    background: var(--redesign-badge-bg, #E8D5A0);
    color: var(--redesign-text-mid, #7A5C3A);
    padding: 3px 11px;
    border-radius: 10px;
    font-size: 11px;
    font-weight: 700;
    white-space: nowrap;
  }

  .section-view-btn {
    display: none;
  }

  .section-show-more {
    display: block;
    width: 100%;
    padding: 12px;
    background: #faf7f2;
    border: none;
    border-top: 1px solid #f0ebe4;
    color: var(--accent-brown);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    text-align: center;
    font-family: 'Scheherazade New', serif;
  }

  .section-show-more:hover {
    background: #f5ebe0;
  }

  @media (max-width: 768px) {
    .homepage-sections {
      padding: 0 var(--space-md);
    }

    .section-header {
      padding: 12px 16px;
    }

    .section-title {
      font-size: 18px;
    }

    .section-table td {
      padding: 10px 12px;
    }

    .section-series-title {
      font-size: 16px;
    }

    .section-table .hide-mobile {
      display: none;
    }
  }

  /* Navigation Tabs - Redesigned per design handoff */
  .nav-tabs {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 32px;
    border-top: 1px solid var(--redesign-badge-bg, #E8D5A0);
  }

  .nav-tabs-container {
    display: flex;
    border-bottom: 2px solid var(--redesign-badge-bg, #E8D5A0);
  }

  .nav-tab {
    padding: 0 28px 13px;
    border: none;
    background: transparent;
    color: var(--redesign-text-muted, #A89070);
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    position: relative;
    transition: all 0.2s;
    font-family: var(--font-cairo, 'Cairo', sans-serif);
    margin-bottom: -2px;
    white-space: nowrap;
  }

  .nav-tab:hover {
    color: var(--redesign-text-mid, #7A5C3A);
  }

  .nav-tab.active {
    color: var(--redesign-brown-dark, #2C1508);
    font-weight: 700;
  }

  .nav-tab.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--redesign-gold-primary, #C49A3C);
  }

  .nav-tab .lucide {
    width: 16px;
    height: 16px;
    margin-inline-end: 6px;
    vertical-align: -2px;
    stroke-width: 2;
  }

  .tab-content {
    display: none;
  }

  .tab-content.active {
    display: block;
  }

  /* Weekly Schedule Section - Card-Based Design */
  .weekly-schedule-section {
    max-width: 1200px;
    margin: 0 auto var(--space-xl);
    padding: var(--space-lg);
  }

  .schedule-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-md);
  }

  .schedule-title {
    font-family: var(--font-arabic-display);
    font-size: 24px;
    font-weight: 700;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  /* Location toggle (In-Person / Online) */
  .schedule-location-toggle {
    display: flex;
    gap: 8px;
    margin-bottom: var(--space-md);
  }

  .location-toggle-btn {
    padding: 10px 20px;
    border: 2px solid var(--border-light);
    border-radius: 8px;
    background: white;
    font-family: inherit;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    color: var(--text-secondary);
  }

  .location-toggle-btn:hover {
    border-color: var(--accent-gold);
    color: var(--accent-gold);
  }

  .location-toggle-btn.active {
    background: var(--primary-dark);
    border-color: var(--primary-dark);
    color: white;
  }

  .location-toggle-btn .lucide {
    width: 16px;
    height: 16px;
    margin-inline-end: 6px;
    vertical-align: -2px;
    stroke-width: 2;
  }

  .location-toggle-count {
    display: inline-block;
    background: rgba(193, 154, 107, 0.2);
    color: var(--accent-gold);
    font-size: 12px;
    padding: 2px 8px;
    border-radius: 10px;
    margin-right: 6px;
  }

  .location-toggle-btn.active .location-toggle-count {
    background: rgba(255, 255, 255, 0.2);
    color: white;
  }

  /* Day tabs - horizontal scrollable */
  .schedule-day-tabs {
    display: flex;
    gap: 6px;
    margin-bottom: var(--space-md);
    overflow-x: auto;
    padding-bottom: 8px;
    -webkit-overflow-scrolling: touch;
  }

  .schedule-day-tabs::-webkit-scrollbar {
    height: 4px;
  }

  .schedule-day-tabs::-webkit-scrollbar-track {
    background: var(--border-light);
    border-radius: 2px;
  }

  .schedule-day-tabs::-webkit-scrollbar-thumb {
    background: var(--accent-gold);
    border-radius: 2px;
  }

  .day-tab {
    flex-shrink: 0;
    padding: 12px 18px;
    border: 2px solid var(--border-light);
    border-radius: 10px;
    background: white;
    font-family: inherit;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    color: var(--text-secondary);
    text-align: center;
    min-width: 70px;
  }

  .day-tab:hover {
    border-color: var(--accent-gold);
    color: var(--accent-gold);
  }

  .day-tab.active {
    background: var(--accent-gold);
    border-color: var(--accent-gold);
    color: var(--primary-dark);
  }

  .day-tab.disabled,
  .day-tab:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    background: var(--border-light);
  }

  .day-tab.disabled:hover,
  .day-tab:disabled:hover {
    border-color: var(--border-light);
    color: var(--text-secondary);
  }

  .day-tab-name {
    display: block;
    font-size: 14px;
    font-weight: 700;
  }

  .day-tab-count {
    display: block;
    font-size: 11px;
    opacity: 0.7;
    margin-top: 2px;
  }

  /* Schedule panels */
  .schedule-location-panel {
    display: none;
  }

  .schedule-location-panel.active {
    display: block;
  }

  .schedule-day-panel {
    display: none;
  }

  .schedule-day-panel.active {
    display: block;
  }

  /* Session cards grid */
  .session-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 16px;
  }

  .session-card {
    background: white;
    border: 2px solid var(--border-light);
    border-radius: 12px;
    padding: 16px;
    text-decoration: none;
    display: block;
    transition: all 0.2s ease;
  }

  .session-card:hover {
    border-color: var(--accent-gold);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px var(--shadow-warm);
  }

  .session-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 10px;
  }

  .session-time {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--cream);
    color: var(--primary-brown);
    font-size: 13px;
    font-weight: 600;
    padding: 5px 10px;
    border-radius: 8px;
  }

  .session-time-icon {
    font-size: 14px;
  }

  .session-badge {
    display: inline-block;
    background: var(--sage);
    color: white;
    font-size: 10px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 8px;
  }

  .session-title {
    font-family: var(--font-arabic-display);
    font-size: 17px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 8px;
    line-height: 1.4;
  }

  .session-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 13px;
    color: var(--text-muted);
  }

  .session-lesson-count {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: var(--accent-gold);
    color: var(--primary-dark);
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 10px;
    font-size: 12px;
  }

  .session-location {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .schedule-empty {
    text-align: center;
    padding: 40px 20px;
    color: var(--text-muted);
  }

  .schedule-empty-icon {
    margin-bottom: 12px;
    opacity: 0.5;
    color: var(--redesign-text-muted, #A89070);
  }

  .schedule-empty-icon .lucide {
    width: 48px;
    height: 48px;
    stroke-width: 1;
  }

  @media (max-width: 768px) {
    .schedule-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }

    .schedule-title {
      font-size: 20px;
    }

    .schedule-location-toggle {
      width: 100%;
    }

    .location-toggle-btn {
      flex: 1;
      text-align: center;
      padding: 8px 12px;
      font-size: 13px;
    }

    .day-tab {
      padding: 10px 14px;
      min-width: 60px;
    }

    .day-tab-name {
      font-size: 13px;
    }

    .session-cards {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .session-card {
      padding: 14px;
    }

    .session-title {
      font-size: 16px;
    }
  }

  @media (max-width: 480px) {
    .weekly-schedule-section {
      padding: var(--space-md);
    }

    .schedule-title {
      font-size: 18px;
    }

    .location-toggle-btn {
      padding: 6px 10px;
      font-size: 12px;
    }

    .day-tab {
      padding: 8px 12px;
      min-width: 55px;
    }

    .day-tab-name {
      font-size: 12px;
    }

    .day-tab-count {
      font-size: 10px;
    }

    .session-card {
      padding: 12px;
    }

    .session-title {
      font-size: 15px;
    }

    .session-time {
      font-size: 12px;
      padding: 4px 8px;
    }

    .session-meta {
      font-size: 12px;
    }
  }

  /* Classic Table-Based Schedule (A/B Test) */
  .schedule-table-wrapper {
    background: white;
    border-radius: 12px;
    box-shadow: 0 2px 12px var(--shadow-warm);
    overflow: hidden;
    border: 2px solid var(--border-light);
  }

  .schedule-table {
    width: 100%;
    border-collapse: collapse;
  }

  .schedule-table th {
    background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary-brown) 100%);
    color: var(--cream);
    font-weight: 600;
    padding: 14px 16px;
    text-align: right;
    font-size: 14px;
  }

  .schedule-table td {
    padding: 12px 16px;
    border-bottom: 1px solid var(--border-light);
    vertical-align: middle;
  }

  .schedule-table tr:last-child td {
    border-bottom: none;
  }

  .schedule-table tr:hover td {
    background: rgba(193, 154, 107, 0.05);
  }

  .schedule-day-cell {
    font-weight: 600;
    color: var(--primary-brown);
    white-space: nowrap;
  }

  .schedule-day-cell.multi-day {
    white-space: normal;
    min-width: 100px;
  }

  .schedule-time-cell {
    color: var(--text-muted);
    font-size: 13px;
    white-space: nowrap;
  }

  .schedule-day-cell.stacked,
  .schedule-time-cell.stacked {
    vertical-align: top;
    white-space: nowrap;
  }

  .stacked-day,
  .stacked-time {
    line-height: 1.6;
  }

  .stacked-day {
    font-weight: 600;
    color: var(--primary-brown);
  }

  .stacked-time {
    color: var(--text-muted);
    font-size: 13px;
  }

  .schedule-series-cell a {
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s;
  }

  .schedule-series-cell a:hover {
    color: var(--accent-gold);
  }

  .schedule-lesson-num {
    display: inline-block;
    background: var(--accent-gold);
    color: var(--primary-dark);
    font-size: 12px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 12px;
    min-width: 45px;
    text-align: center;
  }

  .new-badge {
    display: inline-block;
    background: var(--sage);
    color: white;
    font-size: 10px;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 8px;
    margin-right: 6px;
    vertical-align: middle;
  }

  .schedule-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: var(--space-md);
  }

  .schedule-tab {
    padding: 10px 20px;
    border: 2px solid var(--border-light);
    border-radius: 8px;
    background: white;
    font-family: inherit;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    color: var(--text-secondary);
  }

  .schedule-tab:hover {
    border-color: var(--accent-gold);
    color: var(--accent-gold);
  }

  .schedule-tab.active {
    background: var(--primary-dark);
    border-color: var(--primary-dark);
    color: white;
  }

  .schedule-tab .lucide {
    width: 16px;
    height: 16px;
    margin-inline-end: 6px;
    vertical-align: -2px;
    stroke-width: 2;
  }

  .schedule-tab-count {
    display: inline-block;
    background: rgba(193, 154, 107, 0.2);
    color: var(--accent-gold);
    font-size: 12px;
    padding: 2px 8px;
    border-radius: 10px;
    margin-right: 6px;
  }

  .schedule-tab.active .schedule-tab-count {
    background: rgba(255, 255, 255, 0.2);
    color: white;
  }

  .schedule-panel {
    display: none;
  }

  .schedule-panel.active {
    display: block;
  }

  @media (max-width: 768px) {
    .schedule-tabs {
      width: 100%;
    }

    .schedule-tab {
      flex: 1;
      text-align: center;
      padding: 8px 12px;
      font-size: 13px;
    }

    .schedule-table th,
    .schedule-table td {
      padding: 8px 10px;
      font-size: 12px;
    }

    .schedule-day-cell {
      white-space: normal;
      line-height: 1.4;
    }

    .schedule-day-cell.multi-day {
      min-width: 70px;
    }

    .stacked-day,
    .stacked-time {
      font-size: 12px;
      line-height: 1.5;
    }

    .schedule-lesson-num {
      font-size: 11px;
      padding: 3px 8px;
      min-width: 40px;
    }
  }

  @media (max-width: 480px) {
    .schedule-tab {
      padding: 6px 10px;
      font-size: 12px;
    }

    .schedule-table th,
    .schedule-table td {
      padding: 6px 8px;
      font-size: 11px;
    }

    .schedule-lesson-num {
      font-size: 10px;
      padding: 2px 6px;
      min-width: 36px;
    }
  }

  @media (max-width: 768px) {
    .nav-tab {
      font-size: 14px;
      padding: 12px 16px;
    }
  }

  /* Small phones (below 480px) */
  @media (max-width: 480px) {
    .search-hero {
      min-height: 180px;
      padding: var(--space-md) var(--space-sm);
    }

    .search-hero-quote {
      font-size: 17px;
      line-height: 1.5;
      margin-bottom: 8px;
    }

    .search-hero-subheading {
      font-size: 13px;
      margin-bottom: 16px;
      padding: 0 8px;
      line-height: 1.4;
    }

    .search-hero::before {
      font-size: 80px;
    }

    .search-container {
      padding: 0 4px;
    }

    .search-input {
      font-size: 15px;
      padding: 12px 14px;
    }

    .search-btn {
      padding: 12px 20px;
      font-size: 14px;
    }

    .archive-stats {
      flex-direction: column;
      gap: 10px;
      margin-top: 16px;
    }

    .stat-item {
      padding: 8px 16px;
      width: auto;
    }

    .stat-divider {
      display: none;
    }

    .lecture-count-badge {
      gap: 8px;
      margin-top: 16px;
      padding: 12px 0;
    }

    .count-divider {
      width: 24px;
    }

    .count-number {
      font-size: 18px;
    }

    .count-label {
      font-size: 12px;
    }

    /* Navigation tabs - smaller */
    .nav-tabs-container {
      padding: 0 8px;
    }

    .nav-tab {
      font-size: 13px;
      padding: 10px 8px;
    }

    /* Schedule - compact */
    .weekly-schedule-section {
      padding: var(--space-md);
    }

    .schedule-title {
      font-size: 18px;
    }

    .schedule-tab {
      padding: 6px 10px;
      font-size: 12px;
    }

    .schedule-table th,
    .schedule-table td {
      padding: 6px 8px;
      font-size: 11px;
    }

    .schedule-lesson-num {
      font-size: 10px;
      padding: 2px 6px;
      min-width: 36px;
    }

    /* Sections - compact */
    .homepage-sections {
      padding: 0 var(--space-sm);
    }

    .section-header {
      padding: 10px 12px;
    }

    .section-title {
      font-size: 16px;
    }

    .section-table td {
      padding: 8px 10px;
    }

    .section-series-title {
      font-size: 14px;
    }

    .section-series-subtitle {
      font-size: 11px;
    }
  }

  /* Very small phones (below 360px) */
  @media (max-width: 360px) {
    .search-hero {
      min-height: 160px;
      padding: var(--space-sm);
    }

    .search-hero-quote {
      font-size: 15px;
      line-height: 1.4;
      margin-bottom: 6px;
    }

    .search-hero-subheading {
      font-size: 12px;
      margin-bottom: 12px;
      padding: 0 4px;
      line-height: 1.3;
    }

    .search-hero::before {
      font-size: 60px;
    }

    .search-input {
      font-size: 14px;
      padding: 10px 12px;
    }

    .search-btn {
      padding: 10px 16px;
      font-size: 13px;
    }

    .lecture-count-badge {
      flex-direction: column;
      gap: 4px;
    }

    .count-divider {
      width: 40px;
      height: 1px;
    }

    .count-number {
      font-size: 16px;
    }

    .count-label {
      font-size: 11px;
    }

    /* Navigation tabs - stack or scroll */
    .nav-tabs-container {
      padding: 0 4px;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .nav-tab {
      font-size: 12px;
      padding: 8px 6px;
      white-space: nowrap;
      flex: none;
      min-width: auto;
    }

    /* Schedule - minimal */
    .schedule-title {
      font-size: 16px;
    }

    .schedule-tabs {
      flex-wrap: wrap;
      gap: 4px;
    }

    .schedule-tab {
      padding: 5px 8px;
      font-size: 11px;
    }

    .schedule-table th,
    .schedule-table td {
      padding: 5px 6px;
      font-size: 10px;
    }

    .schedule-lesson-num {
      font-size: 9px;
      padding: 2px 4px;
      min-width: 32px;
    }

    /* Sections - minimal */
    .section-header {
      padding: 8px 10px;
    }

    .section-title {
      font-size: 14px;
    }

    .section-table td {
      padding: 6px 8px;
    }

    .section-series-title {
      font-size: 13px;
    }

    .section-series-subtitle {
      font-size: 10px;
    }

    .section-show-more {
      font-size: 12px;
      padding: 8px;
    }
  }

  /* Skeleton loading styles */
  .series-skeleton {
    padding: 0 var(--space-lg);
  }
  .skeleton-card {
    background: var(--cream);
    border: 2px solid var(--border-light);
    border-radius: 12px;
    padding: 24px;
    margin-bottom: 16px;
  }
  .skeleton-header {
    height: 28px;
