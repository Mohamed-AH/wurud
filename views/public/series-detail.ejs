<style>
  /* Brown/Gold Design for Series Detail Page */
  .series-detail-page {
    padding: 0;
    max-width: 100%;
    overflow-x: hidden;
  }

  /* Ensure all containers have proper width */
  .series-detail-page .container {
    max-width: 1400px;
    width: 100%;
    margin: 0 auto;
    padding: 0 32px;
    box-sizing: border-box;
  }

  .breadcrumb {
    background: var(--cream);
    padding: 16px 0;
    border-bottom: 2px solid var(--accent-amber);
  }

  .breadcrumb .container {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
  }

  .breadcrumb a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.3s;
  }

  .breadcrumb a:hover {
    color: var(--accent-gold);
  }

  .breadcrumb .separator {
    color: var(--text-muted);
  }

  .breadcrumb .current {
    color: var(--text-primary);
    font-weight: 600;
  }

  .series-hero {
    background: linear-gradient(135deg, var(--primary-brown) 0%, var(--sage) 100%);
    padding: 48px 0;
    border-bottom: 3px solid var(--accent-gold);
  }

  .series-category-badge {
    background: var(--accent-gold);
    color: var(--primary-dark);
    padding: 6px 16px;
    border-radius: 16px;
    font-size: 14px;
    font-weight: 600;
    display: inline-block;
    margin-bottom: 16px;
  }

  .series-title {
    font-family: var(--font-arabic-display);
    font-size: 42px;
    color: var(--cream);
    margin-bottom: 12px;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
  }

  .series-title-en {
    font-size: 24px;
    color: var(--cream);
    opacity: 0.9;
    margin-bottom: 24px;
    font-weight: 400;
  }

  .series-sheikh {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--cream);
    font-size: 18px;
  }

  .series-sheikh a {
    color: var(--accent-gold);
    text-decoration: none;
    transition: color 0.3s;
  }

  .series-sheikh a:hover {
    color: var(--accent-amber);
  }

  .stats-section {
    padding: 40px 0;
    background: var(--paper);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 24px;
  }

  .stat-card {
    background: var(--cream);
    border-radius: 12px;
    padding: 24px;
    display: flex;
    align-items: center;
    gap: 16px;
    border: 2px solid var(--accent-amber);
    box-shadow: 0 4px 12px var(--shadow-warm);
  }

  .stat-icon {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--accent-gold) 0%, var(--accent-amber) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .stat-icon svg {
    color: var(--primary-dark);
  }

  .stat-value {
    font-family: var(--font-arabic-display);
    font-size: 32px;
    color: var(--primary-dark);
    font-weight: 700;
  }

  .stat-label {
    color: var(--text-secondary);
    font-size: 14px;
  }

  .content-section {
    padding: 48px 0;
  }

  .section-title {
    font-family: var(--font-arabic-display);
    font-size: 28px;
    color: var(--primary-dark);
    margin-bottom: 24px;
    padding-bottom: 12px;
    border-bottom: 3px solid var(--accent-gold);
  }

  .description-card, .bio-card {
    background: var(--cream);
    border-radius: 12px;
    padding: 32px;
    border: 2px solid var(--accent-amber);
    box-shadow: 0 4px 12px var(--shadow-warm);
    margin-bottom: 48px;
  }

  .description-text, .bio-text {
    color: var(--text-secondary);
    line-height: 1.9;
    font-size: 18px;
  }

  .description-text-en, .bio-text-en {
    color: var(--text-muted);
    line-height: 1.7;
    font-size: 16px;
    margin-top: 16px;
    font-style: italic;
  }

  .btn-link {
    color: var(--accent-gold);
    text-decoration: none;
    font-weight: 600;
    margin-top: 16px;
    display: inline-block;
  }

  .btn-link:hover {
    color: var(--accent-amber);
  }

  .lectures-list {
    display: grid;
    gap: 16px;
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
    box-sizing: border-box;
  }

  .lecture-item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 12px;
    border-radius: 12px;
    transition: all 0.3s ease;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    overflow: hidden;
  }

  .lecture-item-content {
    flex: 1;
    min-width: 0;
    max-width: 100%;
    overflow: hidden;
    box-sizing: border-box;
  }

  .lecture-item:hover {
    background: rgba(193, 154, 107, 0.08);
  }

  .lecture-number-badge {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--accent-gold);
    color: var(--primary-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-arabic-display);
    font-size: 20px;
    font-weight: 700;
    flex-shrink: 0;
    box-shadow: 0 2px 8px var(--shadow-warm);
  }

  .lecture-number-badge.unnumbered {
    background: transparent;
    border: 2px dashed var(--accent-amber);
    color: var(--text-muted);
  }

  .series-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
    margin-bottom: 48px;
  }

  .series-card {
    background: var(--cream);
    border-radius: 12px;
    padding: 24px;
    text-decoration: none;
    transition: all 0.3s;
    border: 2px solid var(--accent-amber);
    display: flex;
    gap: 16px;
    box-shadow: 0 4px 12px var(--shadow-warm);
  }

  .series-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px var(--shadow-warm);
    border-color: var(--accent-gold);
  }

  .series-icon {
    width: 48px;
    height: 48px;
    border-radius: 8px;
    background: var(--accent-gold);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .series-icon svg {
    color: var(--primary-dark);
  }

  .series-content {
    flex: 1;
  }

  .series-title {
    font-family: var(--font-arabic-display);
    font-size: 20px;
    color: var(--primary-dark);
    margin-bottom: 4px;
  }

  .series-title-en {
    color: var(--text-muted);
    font-size: 14px;
    margin-bottom: 12px;
  }

  .series-meta {
    display: flex;
    gap: 12px;
    font-size: 14px;
    color: var(--text-secondary);
  }

  .series-category {
    background: var(--accent-gold);
    color: var(--primary-dark);
    padding: 2px 8px;
    border-radius: 8px;
    font-weight: 600;
  }

  .series-count {
    color: var(--text-secondary);
  }

  .empty-state {
    text-align: center;
    padding: 80px 20px;
    color: var(--text-secondary);
  }

  .empty-icon {
    font-size: 64px;
    margin-bottom: 16px;
    opacity: 0.5;
  }

  /* Search & Filter Controls */
  .search-filter-controls {
    background: var(--cream);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 24px;
    border: 2px solid var(--accent-amber);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .search-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
  }

  .search-input-wrapper {
    flex: 1;
    min-width: 200px;
    position: relative;
  }

  .search-input {
    width: 100%;
    padding: 12px 44px 12px 16px;
    border: 2px solid var(--accent-amber);
    border-radius: 25px;
    font-size: 15px;
    background: white;
    transition: all 0.3s;
    font-family: inherit;
  }

  [dir="ltr"] .search-input {
    padding: 12px 16px 12px 44px;
  }

  .search-input:focus {
    outline: none;
    border-color: var(--accent-gold);
    box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.2);
  }

  .search-input::placeholder {
    color: var(--text-muted);
  }

  .search-icon {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--accent-gold);
    font-size: 18px;
  }

  [dir="ltr"] .search-icon {
    right: auto;
    left: 14px;
  }

  .year-filter-wrapper {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .year-filter-label {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-secondary);
    white-space: nowrap;
  }

  .year-filter-select {
    padding: 10px 16px;
    border: 2px solid var(--accent-amber);
    border-radius: 20px;
    font-size: 14px;
    background: white;
    cursor: pointer;
    transition: all 0.3s;
    min-width: 100px;
    font-family: inherit;
  }

  .year-filter-select:focus {
    outline: none;
    border-color: var(--accent-gold);
  }

  /* Sort Controls */
  .sort-controls {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .sort-label {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-secondary);
  }

  .sort-chips {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .sort-chip {
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 500;
    border: 2px solid var(--accent-amber);
    background: white;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.3s;
  }

  .sort-chip:hover {
    background: var(--accent-amber);
    color: var(--primary-dark);
  }

  .sort-chip.active {
    background: var(--accent-gold);
    color: var(--primary-dark);
    border-color: var(--accent-gold);
    font-weight: 700;
    box-shadow: 0 2px 8px var(--shadow-warm);
  }

  .clear-filters-btn {
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 500;
    border: none;
    background: #dc3545;
    color: white;
    cursor: pointer;
    transition: all 0.3s;
    margin-right: auto;
  }

  .clear-filters-btn:hover {
    background: #c82333;
  }

  .results-count {
    font-size: 14px;
    color: var(--text-secondary);
    padding: 8px 16px;
    background: rgba(212, 175, 55, 0.1);
    border-radius: 20px;
  }

  .no-results {
    text-align: center;
    padding: 40px 20px;
    color: var(--text-secondary);
    background: var(--cream);
    border-radius: 12px;
    display: none;
  }

  .no-results.visible {
    display: block;
  }

  .lecture-item.hidden {
    display: none !important;
  }

  /* Large desktop (1200px and above) - ensure wide layout */
  @media (min-width: 1200px) {
    .series-detail-page .container {
      max-width: 1400px;
      padding: 0 48px;
    }

    .lectures-list {
      max-width: 100%;
    }

    .lecture-item {
      padding: 16px;
    }
  }

  /* Medium desktop (1024px to 1199px) */
  @media (min-width: 1024px) and (max-width: 1199px) {
    .series-detail-page .container {
      max-width: 100%;
      padding: 0 40px;
    }
  }

  /* Tablet (768px and below) */
  @media (max-width: 768px) {
    .series-hero {
      padding: 32px 0;
    }

    .series-title {
      font-size: 32px;
    }

    .series-title-en {
      font-size: 18px;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .series-grid {
      grid-template-columns: 1fr;
    }

    .lecture-item {
      padding: 8px;
      gap: 12px;
    }

    .lecture-number-badge {
      width: 40px;
      height: 40px;
      font-size: 18px;
    }

    .search-filter-controls {
      padding: 16px;
    }

    .search-row {
      flex-direction: column;
      align-items: stretch;
    }

    .search-input-wrapper {
      min-width: 100%;
    }

    .year-filter-wrapper {
      width: 100%;
      justify-content: space-between;
    }

    .sort-controls {
      flex-direction: column;
      align-items: flex-start;
    }

    .sort-chips {
      width: 100%;
    }

    .clear-filters-btn {
      margin-right: 0;
      margin-top: 8px;
    }

    .results-count {
      width: 100%;
      text-align: center;
    }

    .breadcrumb .container {
      flex-wrap: wrap;
      gap: 4px;
      font-size: 13px;
    }

    .section-title {
      font-size: 22px;
    }

    .description-card, .bio-card {
      padding: 20px;
    }

    .content-section {
      padding: 32px 0;
    }
  }

  /* Small phones (below 480px) */
  @media (max-width: 480px) {
    .series-detail-page .container {
      padding-left: 12px;
      padding-right: 12px;
    }

    .series-hero {
      padding: 20px 0;
    }

    .series-title {
      font-size: 24px;
      margin-bottom: 8px;
      line-height: 1.4;
      word-wrap: break-word;
    }

    .series-title-en {
      font-size: 15px;
      margin-bottom: 16px;
    }

    .series-category-badge {
      font-size: 12px;
      padding: 4px 12px;
    }

    .series-sheikh {
      font-size: 14px;
      flex-wrap: wrap;
    }

    .stats-section {
      padding: 24px 0;
    }

    .stats-grid {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .stat-card {
      padding: 14px;
      gap: 12px;
    }

    .stat-icon {
      width: 44px;
      height: 44px;
    }

    .stat-icon svg {
      width: 24px;
      height: 24px;
    }

    .stat-value {
      font-size: 24px;
    }

    .stat-label {
      font-size: 13px;
    }

    .content-section {
      padding: 24px 0;
    }

    .section-title {
      font-size: 18px;
      margin-bottom: 16px;
      padding-bottom: 8px;
    }

    .description-card, .bio-card {
      padding: 14px;
    }

    .description-text, .bio-text {
      font-size: 15px;
      line-height: 1.7;
    }

    /* Search & Filter */
    .search-filter-controls {
      padding: 12px;
      gap: 12px;
    }

    .search-input {
      padding: 10px 40px 10px 14px;
      font-size: 14px;
    }

    [dir="ltr"] .search-input {
      padding: 10px 14px 10px 40px;
    }

    .search-icon {
      font-size: 16px;
    }

    .year-filter-label {
      font-size: 13px;
    }

    .year-filter-select {
      padding: 8px 12px;
      font-size: 13px;
      min-width: 80px;
    }

    .sort-label {
      font-size: 13px;
    }

    .sort-chips {
      gap: 6px;
    }

    .sort-chip {
      padding: 6px 10px;
      font-size: 12px;
    }

    .clear-filters-btn {
      padding: 6px 12px;
      font-size: 12px;
    }

    .results-count {
      font-size: 12px;
      padding: 6px 12px;
    }

    /* Lecture list items */
    .lectures-list {
      gap: 12px;
    }

    .lecture-item {
      padding: 4px;
      gap: 8px;
      flex-direction: row;
      align-items: flex-start;
    }

    .lecture-number-badge {
      width: 32px;
      height: 32px;
      font-size: 14px;
      margin-top: 4px;
    }

    .lecture-item-content {
      flex: 1;
      min-width: 0;
      max-width: calc(100% - 44px);
      width: 100%;
      overflow: hidden;
      box-sizing: border-box;
    }

    .lecture-item-content .lecture-card {
      max-width: 100%;
      width: 100%;
      overflow: hidden;
      box-sizing: border-box;
    }

    .breadcrumb {
      padding: 10px 0;
    }

    .breadcrumb .container {
      font-size: 12px;
    }

    /* Related series grid */
    .series-grid {
      gap: 12px;
    }

    .series-card {
      padding: 14px;
      gap: 12px;
    }

    .series-icon {
      width: 40px;
      height: 40px;
    }

    .series-icon svg {
      width: 28px;
      height: 28px;
    }

    .series-content .series-title {
      font-size: 16px;
    }

    .series-content .series-title-en {
      font-size: 12px;
    }

    .series-meta {
      font-size: 12px;
      gap: 8px;
    }
  }

  /* Very small phones (below 360px) */
  @media (max-width: 360px) {
    .series-detail-page .container {
      padding-left: 8px;
      padding-right: 8px;
    }

    .series-hero {
      padding: 16px 0;
    }

    .series-title {
      font-size: 20px;
    }

    .series-title-en {
      font-size: 13px;
    }

    .stat-card {
      padding: 12px;
      gap: 10px;
    }

    .stat-icon {
      width: 40px;
      height: 40px;
    }

    .stat-icon svg {
      width: 22px;
      height: 22px;
    }

    .stat-value {
      font-size: 22px;
    }

    .stat-label {
      font-size: 12px;
    }

    .section-title {
      font-size: 16px;
    }

    .description-card, .bio-card {
      padding: 12px;
    }

    .description-text, .bio-text {
      font-size: 14px;
    }

    /* Search & Filter */
    .search-filter-controls {
      padding: 10px;
      gap: 10px;
    }

    .search-input {
      padding: 8px 36px 8px 12px;
      font-size: 13px;
    }

    [dir="ltr"] .search-input {
      padding: 8px 12px 8px 36px;
    }

    .year-filter-wrapper {
      flex-direction: column;
      align-items: stretch;
    }

    .year-filter-select {
      width: 100%;
    }

    .sort-chip {
      padding: 5px 8px;
      font-size: 11px;
    }

    .lecture-item {
      padding: 2px;
      gap: 6px;
    }

    .lecture-number-badge {
      width: 28px;
      height: 28px;
      font-size: 12px;
    }

    .lecture-item-content {
      max-width: calc(100% - 38px);
      width: 100%;
      overflow: hidden;
    }

    .lecture-item-content .lecture-card {
      max-width: 100%;
      width: 100%;
      overflow: hidden;
    }

    .series-card {
      padding: 12px;
      flex-direction: column;
      text-align: center;
    }

    .series-icon {
      margin: 0 auto 8px;
    }

    .series-meta {
      justify-content: center;
      flex-wrap: wrap;
    }
  }
</style>

<div class="series-detail-page">
  <!-- Breadcrumb -->
  <nav class="breadcrumb">
    <div class="container">
      <a href="/"><%= locale === 'ar' ? 'الرئيسية' : 'Home' %></a>
      <span class="separator">›</span>
      <span class="current"><%= locale === 'ar' ? series.titleArabic : (series.titleEnglish || series.titleArabic) %></span>
    </div>
  </nav>

  <!-- Hero Section -->
  <div class="series-hero">
    <div class="container">
      <% if (series.category) { %>
        <div class="series-category-badge"><%= translateCategory(series.category) %></div>
      <% } %>

      <% if (locale === 'ar') { %>
        <h1 class="series-title"><%= series.titleArabic %></h1>
        <% if (series.titleEnglish) { %>
          <h2 class="series-title-en"><%= series.titleEnglish %></h2>
        <% } %>
      <% } else { %>
        <h1 class="series-title"><%= series.titleEnglish || series.titleArabic %></h1>
        <% if (series.titleEnglish && series.titleArabic !== series.titleEnglish) { %>
          <h2 class="series-title-en"><%= series.titleArabic %></h2>
        <% } %>
      <% } %>

      <!-- Sheikh Info -->
      <% if (series.sheikhId) { %>
        <div class="series-sheikh">
          <svg class="icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
          <a href="/sheikhs/<%= series.sheikhId.shortId ? series.sheikhId.shortId + '/' + (series.sheikhId.slug_en || '') + '/' + encodeURIComponent(series.sheikhId.slug_ar || '') : (series.sheikhId.slug ? encodeURIComponent(series.sheikhId.slug) : series.sheikhId._id) %>">
            <%= locale === 'ar' ? series.sheikhId.nameArabic : (series.sheikhId.nameEnglish || series.sheikhId.nameArabic) %>
            <% if (locale === 'ar' && series.sheikhId.honorific) { %>
              <span class="honorific"><%= series.sheikhId.honorific %></span>
            <% } %>
          </a>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Statistics -->
  <%
    // Detect if this is a khutba series by checking title only
    const titleAr = series.titleArabic || '';
    const isKhutbaSeries = titleAr.includes('خطب') || titleAr.includes('خطبة');

    // Get stats display settings (with defaults if not provided)
    const minPlaysToShow = typeof seriesStatsSettings !== 'undefined' && seriesStatsSettings.minPlaysToShow ? seriesStatsSettings.minPlaysToShow : 100;
    const showDuration = typeof seriesStatsSettings !== 'undefined' && seriesStatsSettings.showDuration ? seriesStatsSettings.showDuration : false;
    const showPlays = stats.totalPlays >= minPlaysToShow;
  %>
  <div class="stats-section">
    <div class="container">
      <div class="stats-grid">
        <!-- Lecture/Khutbah Count -->
        <div class="stat-card">
          <div class="stat-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"></circle>
              <polygon points="10 8 16 12 10 16 10 8"></polygon>
            </svg>
          </div>
          <div class="stat-content">
            <div class="stat-value"><%= stats.totalLectures %></div>
            <div class="stat-label"><%= locale === 'ar' ? (isKhutbaSeries ? 'خطبة' : 'محاضرة') : (isKhutbaSeries ? 'Khutbahs' : 'Lectures') %></div>
          </div>
        </div>

        <% if (showPlays) { %>
        <!-- Plays (only shown if >= threshold) -->
        <div class="stat-card">
          <div class="stat-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polygon points="23 7 16 12 23 17 23 7"></polygon>
              <polygon points="14 7 7 12 14 17 14 7"></polygon>
            </svg>
          </div>
          <div class="stat-content">
            <div class="stat-value"><%= locale === 'ar' ? stats.totalPlays.toLocaleString('ar-SA') : stats.totalPlays.toLocaleString('en-US') %></div>
            <div class="stat-label"><%= locale === 'ar' ? 'استماع' : 'Plays' %></div>
          </div>
        </div>
        <% } %>

        <% if (showDuration && stats.totalDuration > 0) { %>
        <!-- Duration (only shown if enabled in settings and > 0) -->
        <div class="stat-card">
          <div class="stat-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </div>
          <div class="stat-content">
            <div class="stat-value"><%= Math.floor(stats.totalDuration / 3600) %></div>
            <div class="stat-label"><%= locale === 'ar' ? 'ساعة محتوى' : 'Hours' %></div>
          </div>
        </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Description -->
  <% if (series.descriptionArabic || series.descriptionEnglish) { %>
    <div class="content-section">
      <div class="container">
        <h2 class="section-title"><%= locale === 'ar' ? 'عن السلسلة' : 'About the Series' %></h2>
        <div class="description-card">
          <% if (locale === 'ar') { %>
            <% if (series.descriptionArabic) { %>
              <p class="description-text"><%= series.descriptionArabic %></p>
            <% } %>
          <% } else { %>
            <% if (series.descriptionEnglish) { %>
              <p class="description-text"><%= series.descriptionEnglish %></p>
            <% } else if (series.descriptionArabic) { %>
              <!-- Fallback to Arabic if no English description -->
              <p class="description-text"><%= series.descriptionArabic %></p>
            <% } %>
          <% } %>
        </div>
      </div>
    </div>
  <% } %>

  <!-- Related Khutba Series (for consolidated خطب الجمعة only) -->
  <% if (relatedKhutbaSeries && relatedKhutbaSeries.length > 0) { %>
    <div class="content-section">
      <div class="container">
        <h2 class="section-title"><%= locale === 'ar' ? 'سلاسل الخطب' : 'Khutbah Series' %></h2>
        <div class="series-grid">
          <% relatedKhutbaSeries.forEach(relSeries => { %>
            <a href="/series/<%= relSeries.shortId ? relSeries.shortId + '/' + (relSeries.slug_en || '') + '/' + encodeURIComponent(relSeries.slug_ar || '') : (relSeries.slug ? encodeURIComponent(relSeries.slug) : relSeries._id) %>" class="series-card">
              <div class="series-icon">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                  <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                </svg>
              </div>
              <div class="series-content">
                <h3 class="series-title"><%= locale === 'ar' ? relSeries.titleArabic : (relSeries.titleEnglish || relSeries.titleArabic) %></h3>
                <% if (locale === 'en' && relSeries.titleEnglish && relSeries.titleArabic !== relSeries.titleEnglish) { %>
                  <p class="series-title-en"><%= relSeries.titleArabic %></p>
                <% } else if (locale === 'ar' && relSeries.titleEnglish && relSeries.titleEnglish !== relSeries.titleArabic) { %>
                  <p class="series-title-en"><%= relSeries.titleEnglish %></p>
                <% } %>
                <div class="series-meta">
                  <% if (relSeries.category) { %>
                    <span class="series-category"><%= translateCategory(relSeries.category) %></span>
                  <% } %>
                  <span class="series-count"><%= relSeries.actualLectureCount || 0 %> <%= locale === 'ar' ? 'محاضرة' : 'lectures' %></span>
                </div>
              </div>
            </a>
          <% }); %>
        </div>
      </div>
    </div>
  <% } %>

  <!-- Lectures Section -->
  <div class="content-section">
    <div class="container">
      <h2 class="section-title"><%= relatedKhutbaSeries && relatedKhutbaSeries.length > 0 ? (locale === 'ar' ? 'خطب متفرقة' : 'Miscellaneous Khutbahs') : (locale === 'ar' ? 'محاضرات السلسلة' : 'Series Lectures') %> (<%= lectures.length %>)</h2>

      <%
        // Get display options from series (with defaults)
        const displayOptions = series.displayOptions || {};
        const showSearch = displayOptions.showSearch !== false;
        const showYearFilter = displayOptions.showYearFilter !== false;
        const showSortOptions = displayOptions.showSortOptions !== false;
        const minLecturesForSearch = displayOptions.minLecturesForSearch || 15;
        const minLecturesForYearFilter = displayOptions.minLecturesForYearFilter || 15;

        // Determine if we should show each option based on lecture count
        const lectureCount = lectures ? lectures.length : 0;
        const shouldShowSearch = showSearch && lectureCount >= minLecturesForSearch;
        const shouldShowYearFilter = showYearFilter && lectureCount >= minLecturesForYearFilter;
        const shouldShowSort = showSortOptions;

        // Extract unique Hijri years from lectures
        const hijriYears = new Set();

        // Helper function to extract year from various Hijri date formats
        function extractHijriYear(dateStr) {
          if (!dateStr) return null;

          // Handle "YYYY/MM/DD" format (year first with slashes)
          const yearFirstSlash = dateStr.match(/^(\d{4})\/\d{1,2}\/\d{1,2}$/);
          if (yearFirstSlash) return parseInt(yearFirstSlash[1]);

          // Handle "DD/MM/YYYY" format (year last with slashes)
          const yearLastSlash = dateStr.match(/^\d{1,2}\/\d{1,2}\/(\d{4})$/);
          if (yearLastSlash) return parseInt(yearLastSlash[1]);

          // Handle "YYYY-MM-DD" format (year first with dashes)
          const yearFirstDash = dateStr.match(/^(\d{4})-\d{1,2}-\d{1,2}$/);
          if (yearFirstDash) return parseInt(yearFirstDash[1]);

          return null;
        }

        if (lectures) {
          lectures.forEach(lecture => {
            const year = extractHijriYear(lecture.dateRecordedHijri);
            if (year && year >= 1400 && year <= 1500) {
              hijriYears.add(year);
            }
          });
        }
        const sortedHijriYears = Array.from(hijriYears).sort((a, b) => b - a);

        // Debug: collect sample dates
        const sampleDates = lectures.slice(0, 5).map(l => l.dateRecordedHijri || 'NULL');
      %>

      <script>
        console.log('=== DEBUG: Hijri Year Filter Info ===');
        console.log('Lecture Count:', <%= lectureCount %>);
        console.log('showYearFilter setting:', <%= showYearFilter %>);
        console.log('minLecturesForYearFilter:', <%= minLecturesForYearFilter %>);
        console.log('shouldShowYearFilter:', <%= shouldShowYearFilter %>);
        console.log('Hijri Years Found:', <%= sortedHijriYears.length %>, '[<%= sortedHijriYears.join(", ") %>]');
        console.log('Sample dateRecordedHijri values:', <%- JSON.stringify(sampleDates) %>);
      </script>

      <% if (lectures && lectures.length > 0) { %>
        <% if (shouldShowSearch || shouldShowYearFilter || shouldShowSort) { %>
        <!-- Search & Filter Controls -->
        <div class="search-filter-controls" id="searchFilterControls">
          <% if (shouldShowSearch || shouldShowYearFilter) { %>
          <div class="search-row">
            <% if (shouldShowSearch) { %>
            <div class="search-input-wrapper">
              <input
                type="text"
                id="lectureSearch"
                class="search-input"
                placeholder="<%= locale === 'ar' ? 'ابحث في العناوين...' : 'Search titles...' %>"
                oninput="filterLectures()"
              >
              <span class="search-icon">🔍</span>
            </div>
            <% } %>

            <% if (shouldShowYearFilter && sortedHijriYears.length > 1) { %>
            <div class="year-filter-wrapper">
              <label class="year-filter-label"><%= locale === 'ar' ? 'السنة الهجرية:' : 'Hijri Year:' %></label>
              <select id="yearFilter" class="year-filter-select" onchange="filterLectures()">
                <option value=""><%= locale === 'ar' ? 'الكل' : 'All' %></option>
                <% sortedHijriYears.forEach(year => { %>
                  <option value="<%= year %>"><%= locale === 'ar' ? toArabicNumerals(year) : year %> <%= locale === 'ar' ? 'هـ' : 'H' %></option>
                <% }); %>
              </select>
            </div>
            <% } %>
          </div>
          <% } %>

          <% if (shouldShowSort) { %>
          <div class="sort-controls">
            <span class="sort-label"><%= locale === 'ar' ? 'ترتيب:' : 'Sort:' %></span>
            <div class="sort-chips">
              <button class="sort-chip active" data-sort="order" onclick="sortLectures('order')">
                <%= locale === 'ar' ? 'الترتيب الأصلي' : 'Original Order' %>
              </button>
              <button class="sort-chip" data-sort="number" onclick="sortLectures('number')">
                <%= locale === 'ar' ? 'حسب الرقم' : 'By Number' %>
              </button>
              <button class="sort-chip" data-sort="oldest" onclick="sortLectures('oldest')">
                <%= locale === 'ar' ? 'الأقدم أولاً' : 'Oldest First' %>
              </button>
              <button class="sort-chip" data-sort="newest" onclick="sortLectures('newest')">
                <%= locale === 'ar' ? 'الأحدث أولاً' : 'Newest First' %>
              </button>
            </div>
          </div>
          <% } %>

          <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: center;">
            <button class="clear-filters-btn" onclick="clearAllFilters()" id="clearFiltersBtn" style="display: none;">
              <%= locale === 'ar' ? 'مسح الفلاتر' : 'Clear Filters' %> ✕
            </button>
            <span class="results-count" id="resultsCount" style="display: none;"></span>
          </div>
        </div>
        <% } %>

        <div class="no-results" id="noResults">
          <div style="font-size: 48px; margin-bottom: 16px;">🔍</div>
          <h3><%= locale === 'ar' ? 'لا توجد نتائج' : 'No results found' %></h3>
          <p><%= locale === 'ar' ? 'جرب تغيير كلمات البحث أو الفلاتر' : 'Try changing your search terms or filters' %></p>
        </div>

        <div class="lectures-list" id="lecturesList">
          <% lectures.forEach((lecture, index) => { %>
            <%
              // Extract Hijri year using the helper function defined above
              const hijriYear = extractHijriYear(lecture.dateRecordedHijri) || '';
              // Get title for search
              const searchTitle = (lecture.titleArabic || '') + ' ' + (lecture.titleEnglish || '');
            %>
            <div class="lecture-item"
                 data-sort-order="<%= lecture.sortOrder != null ? lecture.sortOrder : index %>"
                 data-lecture-number="<%= lecture.lectureNumber || 999 %>"
                 data-date="<%= lecture.dateRecorded ? new Date(lecture.dateRecorded).getTime() : 0 %>"
                 data-hijri="<%= lecture.dateRecordedHijri || '' %>"
                 data-hijri-year="<%= hijriYear %>"
                 data-title="<%= searchTitle.toLowerCase() %>"
                 data-index="<%= index %>">
              <% if (lecture.lectureNumber) { %>
                <div class="lecture-number-badge">
                  <%= lecture.lectureNumber %>
                </div>
              <% } else { %>
                <div class="lecture-number-badge unnumbered">
                  <%= index + 1 %>
                </div>
              <% } %>
              <div class="lecture-item-content">
                <%- include('../partials/lectureCard', { lecture, locale }) %>
              </div>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="empty-state">
          <div class="empty-icon">📚</div>
          <h3><%= locale === 'ar' ? 'لا توجد محاضرات في هذه السلسلة حالياً' : 'No lectures in this series currently' %></h3>
        </div>
      <% } %>
    </div>
  </div>
</div>

<script>
  // Play audio using sticky player
  function playAudio(lectureId, title, sheikh) {
    console.log('▶️ Play from series detail page');

    if (window.audioPlayer) {
      window.audioPlayer.play(lectureId, {
        title: title,
        titleArabic: title,
        sheikh: sheikh || ''
      });
    } else {
      console.error('❌ Audio player not initialized');
      alert('مشغل الصوت يتم تحميله، يرجى المحاولة مرة أخرى');
    }
  }

  // Normalize Arabic text for search (remove diacritics, normalize hamza variants, etc.)
  function normalizeArabicForSearch(text) {
    if (!text) return '';
    return text
      .toLowerCase()
      // Remove Arabic diacritics (tashkeel)
      .replace(/[\u064B-\u0652\u0670]/g, '')
      // Normalize hamza variants to alif
      .replace(/[أإآ]/g, 'ا')
      // Normalize ya variants
      .replace(/[ىي]/g, 'ي')
      // Normalize ta marbuta
      .replace(/ة/g, 'ه')
      .trim();
  }

  // Convert Hijri date string (YYYY/MM/DD) to sortable number
  function hijriToSortable(hijriDate) {
    if (!hijriDate) return 0;
    const parts = hijriDate.split('/');
    if (parts.length !== 3) return 0;
    const year = parseInt(parts[0]) || 0;
    const month = parseInt(parts[1]) || 0;
    const day = parseInt(parts[2]) || 0;
    return year * 10000 + month * 100 + day;
  }

  // State
  let currentSort = 'order';
  let currentSearch = '';
  let currentYear = '';

  // Filter and display lectures
  function filterLectures() {
    const searchInput = document.getElementById('lectureSearch');
    const yearSelect = document.getElementById('yearFilter');
    const lecturesList = document.getElementById('lecturesList');
    const noResults = document.getElementById('noResults');
    const resultsCount = document.getElementById('resultsCount');
    const clearBtn = document.getElementById('clearFiltersBtn');

    if (!lecturesList) return;

    currentSearch = searchInput ? normalizeArabicForSearch(searchInput.value) : '';
    currentYear = yearSelect ? yearSelect.value : '';

    const lectures = Array.from(lecturesList.querySelectorAll('.lecture-item'));
    let visibleCount = 0;

    lectures.forEach(lecture => {
      let visible = true;

      // Search filter
      if (currentSearch) {
        const title = normalizeArabicForSearch(lecture.dataset.title || '');
        if (!title.includes(currentSearch)) {
          visible = false;
        }
      }

      // Year filter
      if (visible && currentYear) {
        const lectureYear = lecture.dataset.hijriYear || '';
        if (lectureYear !== currentYear) {
          visible = false;
        }
      }

      // Apply visibility
      lecture.classList.toggle('hidden', !visible);
      if (visible) visibleCount++;
    });

    // Show/hide no results message
    if (noResults) {
      noResults.classList.toggle('visible', visibleCount === 0 && (currentSearch || currentYear));
    }

    // Update results count
    if (resultsCount) {
      if (currentSearch || currentYear) {
        const locale = document.documentElement.lang || 'ar';
        if (locale === 'ar') {
          resultsCount.textContent = `عرض ${visibleCount} من ${lectures.length}`;
        } else {
          resultsCount.textContent = `Showing ${visibleCount} of ${lectures.length}`;
        }
        resultsCount.style.display = 'inline-block';
      } else {
        resultsCount.style.display = 'none';
      }
    }

    // Show/hide clear button
    if (clearBtn) {
      const hasFilters = currentSearch || currentYear || currentSort !== 'order';
      clearBtn.style.display = hasFilters ? 'block' : 'none';
    }
  }

  // Sort lectures
  function sortLectures(sortType) {
    const lecturesList = document.getElementById('lecturesList');
    if (!lecturesList) return;

    const lectures = Array.from(lecturesList.querySelectorAll('.lecture-item'));

    // Sort lectures based on type
    lectures.sort((a, b) => {
      if (sortType === 'order') {
        // Original order from Excel/import (uses sortOrder field)
        const orderA = parseInt(a.dataset.sortOrder) || 0;
        const orderB = parseInt(b.dataset.sortOrder) || 0;
        return orderA - orderB;
      } else if (sortType === 'number') {
        // By lecture number
        const numA = parseInt(a.dataset.lectureNumber) || 999;
        const numB = parseInt(b.dataset.lectureNumber) || 999;
        return numA - numB;
      } else if (sortType === 'oldest') {
        // Try Hijri date first, then Gregorian, then sort order
        const hijriA = hijriToSortable(a.dataset.hijri);
        const hijriB = hijriToSortable(b.dataset.hijri);
        if (hijriA !== hijriB && hijriA !== 0 && hijriB !== 0) {
          return hijriA - hijriB;
        }
        const dateA = parseInt(a.dataset.date) || 0;
        const dateB = parseInt(b.dataset.date) || 0;
        if (dateA !== dateB) {
          return dateA - dateB;
        }
        const orderA = parseInt(a.dataset.sortOrder) || 0;
        const orderB = parseInt(b.dataset.sortOrder) || 0;
        return orderA - orderB;
      } else if (sortType === 'newest') {
        // Try Hijri date first, then Gregorian, then sort order
        const hijriA = hijriToSortable(a.dataset.hijri);
        const hijriB = hijriToSortable(b.dataset.hijri);
        if (hijriA !== hijriB && hijriA !== 0 && hijriB !== 0) {
          return hijriB - hijriA;
        }
        const dateA = parseInt(a.dataset.date) || 0;
        const dateB = parseInt(b.dataset.date) || 0;
        if (dateA !== dateB) {
          return dateB - dateA;
        }
        const orderA = parseInt(a.dataset.sortOrder) || 0;
        const orderB = parseInt(b.dataset.sortOrder) || 0;
        return orderB - orderA;
      }
      return 0;
    });

    // Re-append lectures in sorted order
    lectures.forEach(lecture => lecturesList.appendChild(lecture));

    // Update active chip
    document.querySelectorAll('.sort-chip').forEach(chip => {
      chip.classList.toggle('active', chip.dataset.sort === sortType);
    });

    currentSort = sortType;

    // Update clear button visibility
    const clearBtn = document.getElementById('clearFiltersBtn');
    if (clearBtn) {
      const hasFilters = currentSearch || currentYear || currentSort !== 'order';
      clearBtn.style.display = hasFilters ? 'block' : 'none';
    }
  }

  // Clear all filters and sort
  function clearAllFilters() {
    // Clear search
    const searchInput = document.getElementById('lectureSearch');
    if (searchInput) searchInput.value = '';

    // Clear year filter
    const yearSelect = document.getElementById('yearFilter');
    if (yearSelect) yearSelect.value = '';

    // Reset state
    currentSearch = '';
    currentYear = '';

    // Reset sort to default
    sortLectures('order');

    // Re-apply filters (will show all)
    filterLectures();

    // Hide clear button
    const clearBtn = document.getElementById('clearFiltersBtn');
    if (clearBtn) clearBtn.style.display = 'none';

    // Hide results count
    const resultsCount = document.getElementById('resultsCount');
    if (resultsCount) resultsCount.style.display = 'none';
  }

  // Legacy function for backward compatibility
  function clearSort() {
    clearAllFilters();
  }
</script>
